---
import DocsLayout from '../../layouts/DocsLayout.astro';

const pages = [
  { href: '/docs/dashboard', title: 'Home & Dashboard', description: 'Workspace briefing with micro-visualizations, execution lanes, and live operational signals.', screenshot: '/screenshots/home-list.png' },
  { href: '/docs/tasks', title: 'Task Execution', description: 'Status-driven task flow, AI-assisted creation, bento detail view, and bulk operations.', screenshot: '/screenshots/dashboard-list.png' },
  { href: '/docs/projects', title: 'Projects', description: 'Portfolio organization with working directories, completion donuts, and scoped execution.', screenshot: '/screenshots/projects-list.png' },
  { href: '/docs/workflows', title: 'Workflows', description: 'Six execution patterns, blueprint catalog with lineage, and step-level retry.', screenshot: '/screenshots/workflows-blueprints.png' },
  { href: '/docs/profiles', title: 'Profiles', description: '21 curated profiles with cross-provider support, auto-detect routing, and supervised self-improvement.', screenshot: '/screenshots/profiles-list.png' },
  { href: '/docs/schedules', title: 'Schedules', description: 'Human-friendly intervals, cron expressions, runtime targeting, and governed execution.', screenshot: '/screenshots/schedules-list.png' },
  { href: '/docs/documents', title: 'Documents', description: 'Drag-and-drop upload, automatic text extraction, agent context injection, and output generation.', screenshot: '/screenshots/documents-list.png' },
  { href: '/docs/inbox', title: 'Human-in-the-Loop', description: 'Approval controls, ambient toasts, agent questions, and batch context proposals.', screenshot: '/screenshots/inbox-permissions.png' },
  { href: '/docs/monitoring', title: 'Monitoring', description: 'Streaming logs with click-to-navigate, auto-pause on tab switch, and event filtering.', screenshot: '/screenshots/monitor-list.png' },
  { href: '/docs/costs', title: 'Cost & Usage', description: 'Cross-runtime spend, budget enforcement, project budgets, and execution path tracking.', screenshot: '/screenshots/cost-codex-claude-code.png' },
  { href: '/docs/agents', title: 'Agent Integration', description: 'Dual-runtime execution with Claude SDK and Codex App Server, profile-backed policies.', screenshot: '/screenshots/profiles-detail.png' },
  { href: '/docs/chat', title: 'Chat', description: 'Conversational AI with model selection, suggested prompts, entity CRUD, and Quick Access navigation.', screenshot: '/screenshots/chat-list.png' },
  { href: '/docs/environment', title: 'Environment', description: 'Scan, audit, and manage Claude Code and Codex CLI environments with health scoring and artifact discovery.', screenshot: '/screenshots/environment-list.png' },
  { href: '/docs/settings', title: 'Settings', description: 'Permission presets with risk tiers, browser tools, chat defaults, authentication, and data management.', screenshot: '/screenshots/settings-list.png' },
];
---
<DocsLayout title="Overview" description="Comprehensive documentation for Stagent — a governed AI agent operations workspace with reusable profiles, workflows, documents, schedules, and local-first oversight.">
  <h1>Stagent Documentation</h1>
  <p>Stagent is a local-first AI agent operations workspace. Explore the product surfaces below to see how home, execution, projects, workflows, profiles, schedules, documents, chat, environment, monitoring, cost governance, and approvals fit together.</p>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12 not-prose">
    {pages.map(({ href, title, description, screenshot }) => (
      <a href={href} class="group block border border-border rounded-lg overflow-hidden hover:border-primary/40 transition-colors">
        <div class="aspect-video overflow-hidden bg-surface-raised">
          <img
            src={screenshot}
            alt={title}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-300"
          />
        </div>
        <div class="p-4">
          <h3 class="font-semibold text-sm text-text mb-1">{title}</h3>
          <p class="text-xs text-text-muted leading-relaxed">{description}</p>
        </div>
      </a>
    ))}
  </div>
</DocsLayout>
