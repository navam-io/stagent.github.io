---
import DocsLayout from '../../layouts/DocsLayout.astro';

const pages = [
  { href: '/docs/dashboard', title: 'Home & Dashboard', description: 'Workspace briefing, execution lanes, and task-level operational signals.', screenshot: '/screenshots/home-list.png' },
  { href: '/docs/tasks', title: 'Task Execution', description: 'Status-driven task flow, detailed execution records, and task creation.', screenshot: '/screenshots/dashboard-list.png' },
  { href: '/docs/projects', title: 'Projects', description: 'Portfolio-level organization, scoped execution queues, and project context.', screenshot: '/screenshots/projects-list.png' },
  { href: '/docs/workflows', title: 'Workflows', description: 'Reusable multi-step automations, blueprint templates, and step orchestration.', screenshot: '/screenshots/workflows-blueprints.png' },
  { href: '/docs/profiles', title: 'Profiles', description: 'Curated agent profiles with prompts, tool policies, and runtime tuning.', screenshot: '/screenshots/profiles-list.png' },
  { href: '/docs/schedules', title: 'Schedules', description: 'Recurring and one-shot runs with timing, expiry, and profile selection.', screenshot: '/screenshots/schedules-list.png' },
  { href: '/docs/documents', title: 'Documents', description: 'Upload, inspect, and link files to tasks and projects.', screenshot: '/screenshots/documents-list.png' },
  { href: '/docs/inbox', title: 'Human-in-the-Loop', description: 'Permission reviews, messages, completions, and failure triage.', screenshot: '/screenshots/inbox-permissions.png' },
  { href: '/docs/monitoring', title: 'Monitoring', description: 'Live agent visibility with activity cards, filters, and log streaming.', screenshot: '/screenshots/monitor-list.png' },
  { href: '/docs/agents', title: 'Agent Integration', description: 'Runtime execution, profile-backed policies, and governed tool use.', screenshot: '/screenshots/profiles-detail.png' },
  { href: '/docs/settings', title: 'Settings', description: 'Authentication, default permissions, and workspace data management.', screenshot: '/screenshots/settings-list.png' },
];
---
<DocsLayout title="Overview" description="Comprehensive documentation for Stagent — a governed AI agent operations workspace with reusable profiles, workflows, documents, schedules, and local-first oversight.">
  <h1>Stagent Documentation</h1>
  <p>Stagent is a local-first AI agent operations workspace. Explore the product surfaces below to see how home, execution, projects, workflows, profiles, schedules, documents, monitoring, and approvals fit together.</p>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12 not-prose">
    {pages.map(({ href, title, description, screenshot }) => (
      <a href={href} class="group block border border-border rounded-lg overflow-hidden hover:border-primary/40 transition-colors">
        <div class="aspect-video overflow-hidden bg-surface-raised">
          <img
            src={screenshot}
            alt={title}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-300"
          />
        </div>
        <div class="p-4">
          <h3 class="font-semibold text-sm text-text mb-1">{title}</h3>
          <p class="text-xs text-text-muted leading-relaxed">{description}</p>
        </div>
      </a>
    ))}
  </div>
</DocsLayout>
