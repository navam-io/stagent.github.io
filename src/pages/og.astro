---
/**
 * OG Image page — rendered at 1200×630 then screenshotted to public/og-image.png
 * Standalone page with no layout wrapper, fixed dimensions, no overflow.
 */
import "@fontsource/dm-serif-display/400.css";
import "@fontsource/jetbrains-mono/400.css";
import { isoProject, isoEllipse, isoPlatform, isoGridLines } from '../utils/isometric';

// Reuse HarnessOrbit geometry — center platform + 3 orbit rings + 7 satellites
const centerPlatform = isoPlatform(-35, -35, 0, 70, 70, 6);
const centerTop = isoProject(0, 0, 6);
const centerGrid = isoGridLines(-35, -35, 6, 70, 70, 5);

const orbits = [
  { label: 'HARNESS', radius: 75, opacity: 0.85, color: '#d4a843' },
  { label: 'ORCHESTRATION', radius: 120, opacity: 0.75, color: '#4db8a4' },
  { label: 'INFRASTRUCTURE', radius: 165, opacity: 0.6, color: '#e8e4df' },
];

const orbitEllipses = orbits.map((o) => ({
  ...o,
  ...isoEllipse(0, 0, 6, o.radius),
  labelPos: isoProject(0, -o.radius, 6),
}));

const satellites = [
  { x: 75, y: 0, z: 15, r: 5.5, orbitIdx: 0 },
  { x: -75, y: 0, z: 12, r: 5.5, orbitIdx: 0 },
  { x: 0, y: 75, z: 18, r: 4.5, orbitIdx: 0 },
  { x: 55, y: -55, z: 10, r: 4.5, orbitIdx: 1 },
  { x: -55, y: 55, z: 14, r: 4.5, orbitIdx: 1 },
  { x: 110, y: -70, z: 8, r: 4, orbitIdx: 2 },
  { x: -110, y: 70, z: 6, r: 4, orbitIdx: 2 },
].map((s) => ({
  ...s,
  p: isoProject(s.x, s.y, s.z),
  dropTo: isoProject(s.x, s.y, 0),
}));

const satellitesByOrbit = [0, 1, 2].map((idx) => satellites.filter((s) => s.orbitIdx === idx));
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex" />
  <title>OG Image — Stagent</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 1200px;
      height: 630px;
      overflow: hidden;
      background: #0a0a0a;
      color: #e8e4df;
    }

    .og-container {
      position: relative;
      width: 1200px;
      height: 630px;
    }

    /* ── Wordmark: top-left, massive ── */
    .wordmark {
      position: absolute;
      top: 56px;
      left: 72px;
      z-index: 3;
      font-family: "JetBrains Mono", monospace;
      font-size: 136px;
      font-weight: 400;
      letter-spacing: 0.18em;
      color: #d4a843;
      line-height: 1;
    }

    /* ── Orbit: background layer, center-right ── */
    .orbit-bg {
      position: absolute;
      right: -20px;
      top: 50%;
      transform: translateY(-50%);
      opacity: 0.85;
      z-index: 1;
    }

    .orbit-svg {
      width: 680px;
      height: 460px;
    }

    .glow {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, #d4a84340 0%, transparent 70%);
      z-index: 0;
    }

    /* ── Left content: tagline + pills, left-aligned under wordmark ── */
    .center-content {
      position: absolute;
      left: 72px;
      top: 280px;
      z-index: 2;
      text-align: left;
      white-space: nowrap;
    }

    .tagline {
      font-family: "JetBrains Mono", monospace;
      font-size: 31px;
      line-height: 1.15;
      color: #d4cfc9;
      letter-spacing: 0.02em;
      margin-bottom: 28px;
    }

    .pills {
      display: flex;
      gap: 16px;
      justify-content: flex-start;
    }

    .pill {
      font-family: "JetBrains Mono", monospace;
      font-size: 16px;
      letter-spacing: 0.04em;
      color: #d4a843;
      border: 1.5px solid #d4a84366;
      border-radius: 20px;
      padding: 8px 24px;
      background: #d4a84310;
    }

    /* ── URL: bottom-right ── */
    .url {
      position: absolute;
      bottom: 36px;
      right: 48px;
      z-index: 3;
      font-family: "JetBrains Mono", monospace;
      font-size: 28px;
      letter-spacing: 0.08em;
      color: #d4a84399;
    }

    /* ── Bottom accent line ── */
    .accent-line {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg, transparent 5%, #d4a84340 30%, #d4a84380 50%, #d4a84340 70%, transparent 95%);
      z-index: 3;
    }
  </style>
</head>
<body>
  <div class="og-container">
    <!-- Wordmark at top-left -->
    <div class="wordmark">STAGENT</div>

    <!-- Orbit as background layer -->
    <div class="orbit-bg">
      <div class="glow"></div>
      <svg
        class="orbit-svg"
        viewBox="0 0 500 320"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <filter id="amber-glow" x="-50%" y="-50%" width="200%" height="200%">
            <feDropShadow dx="0" dy="0" stdDeviation="6" flood-color="#d4a843" flood-opacity="0.4" />
          </filter>
          <linearGradient id="amber-side-fade" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#d4a843" stop-opacity="0.25" />
            <stop offset="100%" stop-color="#d4a843" stop-opacity="0.08" />
          </linearGradient>
          <linearGradient id="amber-side-right" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#d4a843" stop-opacity="0.18" />
            <stop offset="100%" stop-color="#d4a843" stop-opacity="0.05" />
          </linearGradient>
        </defs>

        <g transform="translate(250, 150)">
          {/* Orbit rings + satellites */}
          {orbitEllipses.map((o, oi) => (
            <g style={`opacity: ${o.opacity}`}>
              <ellipse
                cx={o.cx}
                cy={o.cy}
                rx={o.rx}
                ry={o.ry}
                stroke={o.color}
                stroke-width="0.75"
                fill="none"
                stroke-dasharray="4 3"
              />
              <text
                x={o.labelPos.x}
                y={o.labelPos.y - 6}
                text-anchor="middle"
                fill={o.color}
                font-family="'JetBrains Mono', monospace"
                font-size="13"
                letter-spacing="0.08em"
                font-weight="bold"
                opacity="1"
              >
                {o.label}
              </text>

              {satellitesByOrbit[oi].map((s) => (
                <g>
                  <line
                    x1={s.p.x}
                    y1={s.p.y}
                    x2={s.dropTo.x}
                    y2={s.dropTo.y}
                    stroke="#e8e4df"
                    stroke-width="0.3"
                    stroke-dasharray="2 3"
                    opacity="0.08"
                  />
                  <circle
                    cx={s.p.x}
                    cy={s.p.y}
                    r={s.r}
                    fill={o.color}
                    opacity="0.35"
                  />
                </g>
              ))}
            </g>
          ))}

          {/* Center platform */}
          <g>
            <polygon
              points={centerPlatform.left}
              fill="url(#amber-side-fade)"
              stroke="#d4a843"
              stroke-width="0.75"
              stroke-opacity="0.5"
            />
            <polygon
              points={centerPlatform.right}
              fill="url(#amber-side-right)"
              stroke="#d4a843"
              stroke-width="0.75"
              stroke-opacity="0.5"
            />
            <polygon
              points={centerPlatform.top}
              fill="#d4a84320"
              stroke="#d4a843"
              stroke-width="1.5"
            />

            {/* Grid on center platform */}
            {centerGrid.map((d) => (
              <path
                d={d}
                stroke="#d4a843"
                stroke-width="0.3"
                opacity="0.12"
              />
            ))}

            {/* Diamond marker on platform */}
            <polygon
              points={`${centerTop.x},${centerTop.y - 8} ${centerTop.x + 6},${centerTop.y} ${centerTop.x},${centerTop.y + 8} ${centerTop.x - 6},${centerTop.y}`}
              fill="#d4a843"
              opacity="0.6"
            />

            {/* Amber glow on center */}
            <polygon
              points={centerPlatform.top}
              fill="none"
              filter="url(#amber-glow)"
              stroke="#d4a843"
              stroke-width="0.5"
              opacity="0.3"
            />
          </g>
        </g>
      </svg>
    </div>

    <!-- Subtitle + pills centered on orbit -->
    <div class="center-content">
      <div class="tagline">Multi-Agent Autonomous Harness</div>
      <div class="pills">
        <span class="pill">Any Model</span>
        <span class="pill">Any Tool</span>
        <span class="pill">Any Timeline</span>
      </div>
    </div>

    <!-- Domain bottom-right -->
    <div class="url">stagent.io</div>
    <div class="accent-line"></div>
  </div>
</body>
</html>
