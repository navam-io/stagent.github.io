---
/**
 * OG Image page — rendered at 1200×630 then screenshotted to public/og-image.png
 * Standalone page with no layout wrapper, fixed dimensions, no overflow.
 */
import "@fontsource/geist-sans/700.css";
import "@fontsource-variable/geist-mono";
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex" />
  <title>OG Image — Stagent</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      width: 1200px;
      height: 630px;
      overflow: hidden;
      background: oklch(0.13 0.02 250);
      color: oklch(0.93 0.01 250);
    }

    .og-container {
      position: relative;
      width: 1200px;
      height: 630px;
    }

    /* ── Background glow ── */
    .glow {
      position: absolute;
      top: 50%;
      right: 200px;
      transform: translateY(-50%);
      width: 500px;
      height: 500px;
      border-radius: 50%;
      background: radial-gradient(circle, oklch(0.65 0.18 250 / 0.15) 0%, transparent 70%);
      z-index: 0;
    }

    /* ── Wordmark ── */
    .wordmark {
      position: absolute;
      top: 90px;
      left: 72px;
      z-index: 3;
      font-family: "Geist Mono Variable", monospace;
      font-size: 136px;
      font-weight: 400;
      letter-spacing: 0.18em;
      color: oklch(0.65 0.18 250);
      line-height: 1;
    }

    /* ── Content ── */
    .center-content {
      position: absolute;
      left: 72px;
      top: 320px;
      z-index: 2;
      text-align: left;
    }

    .tagline {
      font-family: "Geist Sans", system-ui, sans-serif;
      font-size: 32px;
      font-weight: 700;
      line-height: 1.3;
      color: oklch(0.85 0.01 250);
      margin-bottom: 28px;
      max-width: 700px;
    }

    .pills {
      display: flex;
      gap: 16px;
      justify-content: flex-start;
    }

    .pill {
      font-family: "Geist Mono Variable", monospace;
      font-size: 16px;
      letter-spacing: 0.04em;
      color: oklch(0.65 0.18 250);
      border: 1.5px solid oklch(0.65 0.18 250 / 0.4);
      border-radius: 8px;
      padding: 8px 24px;
      background: oklch(0.65 0.18 250 / 0.06);
    }

    /* ── URL ── */
    .url {
      position: absolute;
      bottom: 36px;
      right: 48px;
      z-index: 3;
      font-family: "Geist Mono Variable", monospace;
      font-size: 28px;
      letter-spacing: 0.08em;
      color: oklch(0.65 0.18 250 / 0.6);
    }

    /* ── Accent line ── */
    .accent-line {
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 2px;
      background: linear-gradient(90deg, transparent 5%, oklch(0.65 0.18 250 / 0.25) 30%, oklch(0.65 0.18 250 / 0.5) 50%, oklch(0.65 0.18 250 / 0.25) 70%, transparent 95%);
      z-index: 3;
    }

    /* ── Architecture lines ── */
    .arch-lines {
      position: absolute;
      right: 60px;
      top: 100px;
      z-index: 1;
      opacity: 0.6;
    }
  </style>
</head>
<body>
  <div class="og-container">
    <div class="glow"></div>

    <div class="wordmark">STAGENT</div>

    <!-- Architecture layers as visual element -->
    <div class="arch-lines">
      <svg width="400" height="380" viewBox="0 0 400 380" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="20" y="20" width="360" height="70" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
        <text x="40" y="60" fill="oklch(0.65 0.18 250)" font-family="'Geist Mono Variable', monospace" font-size="14" font-weight="600">HUMAN LAYER</text>

        <rect x="20" y="110" width="360" height="70" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
        <text x="40" y="150" fill="oklch(0.65 0.18 250)" font-family="'Geist Mono Variable', monospace" font-size="14" font-weight="600">COORDINATION</text>

        <rect x="20" y="200" width="360" height="70" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
        <text x="40" y="240" fill="oklch(0.65 0.18 250)" font-family="'Geist Mono Variable', monospace" font-size="14" font-weight="600">AGENT LAYER</text>

        <rect x="20" y="290" width="360" height="70" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
        <text x="40" y="330" fill="oklch(0.65 0.18 250)" font-family="'Geist Mono Variable', monospace" font-size="14" font-weight="600">DATA LAYER</text>

        <!-- Connecting dots -->
        <circle cx="200" cy="97" r="3" fill="oklch(0.65 0.18 250)" />
        <circle cx="200" cy="187" r="3" fill="oklch(0.65 0.18 250)" />
        <circle cx="200" cy="277" r="3" fill="oklch(0.65 0.18 250)" />
      </svg>
    </div>

    <div class="center-content">
      <div class="tagline">AI-powered task management with human-in-the-loop oversight</div>
      <div class="pills">
        <span class="pill">18 Features</span>
        <span class="pill">7 Sprints</span>
        <span class="pill">Open Source</span>
      </div>
    </div>

    <div class="url">stagent.io</div>
    <div class="accent-line"></div>
  </div>
</body>
</html>
