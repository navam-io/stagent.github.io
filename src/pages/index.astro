---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import Thesis from '../components/sections/Thesis.astro';
import Pillars from '../components/sections/Pillars.astro';
import Architecture from '../components/sections/Architecture.astro';
import Progress from '../components/sections/Progress.astro';
import Competitive from '../components/sections/Competitive.astro';
import Timeline from '../components/sections/Timeline.astro';
import Vision from '../components/sections/Vision.astro';
import CTAFooter from '../components/sections/CTAFooter.astro';
import Footer from '../components/Footer.astro';
import { SITE, ORGANIZATION, PUBLISHER } from '../data/seo';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    ...ORGANIZATION,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    publisher: PUBLISHER,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Stagent',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'macOS, Windows, Linux',
    description: SITE.description,
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    license: 'https://www.apache.org/licenses/LICENSE-2.0',
    programmingLanguage: ['Rust', 'TypeScript'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: SITE.url,
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is Stagent?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Stagent is a desktop-native, open-source harness that turns high-level goals into observable, long-running agent workflows — across any model, any tool, any timeline.',
        },
      },
      {
        '@type': 'Question',
        name: 'What makes Stagent different from other AI agent tools?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Stagent differentiates through five pillars: long-horizon task persistence (tasks that survive beyond sessions), multi-model orchestration (right model for each subtask), memory-native architecture (four-tier hierarchical memory), graduated autonomy (trust earned through demonstrated competence), and hybrid execution (desktop-native with cloud reach).',
        },
      },
      {
        '@type': 'Question',
        name: 'What technology stack does Stagent use?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Stagent uses a Rust + TypeScript hybrid architecture built on Tauri. Rust handles system integration, WASM sandboxing, and persistent storage. TypeScript handles LLM SDK integration and agent execution. MCP and A2A protocols form the communication backbone.',
        },
      },
      {
        '@type': 'Question',
        name: 'Is Stagent open source?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, Stagent is fully open source under the Apache 2.0 license. The orchestration layer — task graphs, memory, graduated autonomy, checkpoint/resume — is model-independent and community-driven.',
        },
      },
    ],
  },
];
---
<Layout jsonLd={jsonLd}>
  <Nav />
  <main>
    <Hero />
    <Problem />
    <Thesis />
    <Pillars />
    <Architecture />
    <Progress />
    <Competitive />
    <Timeline />
    <Vision />
    <CTAFooter />
  </main>
  <Footer />
</Layout>
