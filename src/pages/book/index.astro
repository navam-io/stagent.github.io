---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/book.css';
import { PARTS, CHAPTERS, CHAPTER_SLUG_MAP } from '../../lib/book/content';
import { READING_PATHS } from '../../lib/book/reading-paths';
import { SITE, PUBLISHER } from '../../data/seo';
import BrowserFrame from '../../components/ui/BrowserFrame.astro';

const totalReadingTime = CHAPTERS.reduce((sum, ch) => sum + ch.readingTime, 0);

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Book',
    name: 'AI Native: Building Autonomous Business Systems with AI Agents',
    description: 'A practical guide to building AI-native applications, from single-agent task execution to fully autonomous business processes.',
    publisher: PUBLISHER,
    url: `${SITE.url}/book/`,
    inLanguage: 'en',
    numberOfPages: CHAPTERS.length,
    accessMode: 'textual',
    isAccessibleForFree: true,
  },
];
---
<Layout
  title="AI Native — The Book | Stagent"
  description="A practical guide to building AI-native applications. 9 chapters covering project management, task execution, workflows, and autonomous business processes."
  jsonLd={jsonLd}
>
  <Nav />

  <main class="pt-28 pb-32">
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-6 text-center mb-20" data-animate>
      <p class="font-mono text-xs tracking-widest text-success uppercase mb-4">
        Free Online Book
      </p>
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight mb-4">
        AI Native
      </h1>
      <p class="text-xl sm:text-2xl text-text-muted max-w-2xl mx-auto mb-6">
        Building Autonomous Business Systems with AI Agents
      </p>
      <p class="text-sm text-text-muted max-w-xl mx-auto mb-8">
        A practical guide from single-agent task execution to fully autonomous
        business processes. Every pattern demonstrated with working code from
        Stagent — a tool that built itself.
      </p>
      <div class="flex items-center justify-center gap-6 text-sm text-text-muted mb-10">
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
          {CHAPTERS.length} chapters
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
          </svg>
          ~{totalReadingTime} min read
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
          </svg>
          3 parts
        </span>
      </div>
      <a
        href={`/book/${CHAPTER_SLUG_MAP['ch-1']}`}
        class="inline-flex items-center gap-2 bg-primary text-white font-medium px-6 py-3 rounded-lg hover:opacity-90 transition-opacity no-underline"
      >
        Start Reading
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </section>

    <!-- Parts Grid -->
    <section class="max-w-5xl mx-auto px-6 mb-20" data-animate>
      <div class="grid md:grid-cols-3 gap-6">
        {PARTS.map((part) => {
          const partChapters = CHAPTERS.filter((ch) => ch.part.number === part.number);
          return (
            <div class="rounded-xl border border-border bg-surface-raised p-6 hover:border-primary/30 transition-colors">
              <div class="flex items-baseline gap-2 mb-3">
                <span class="font-mono text-xs tracking-wider text-primary">Part {part.number}</span>
              </div>
              <h2 class="text-xl font-bold mb-2">{part.title}</h2>
              <p class="text-sm text-text-muted mb-5">{part.description}</p>
              <div class="space-y-2">
                {partChapters.map((ch) => (
                  <a
                    href={`/book/${CHAPTER_SLUG_MAP[ch.id]}`}
                    class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-surface-overlay transition-colors group no-underline"
                  >
                    <span class="w-6 h-6 rounded-md bg-primary-dim text-primary text-xs font-semibold flex items-center justify-center shrink-0">
                      {ch.number}
                    </span>
                    <div class="min-w-0">
                      <p class="text-sm font-medium group-hover:text-primary transition-colors truncate">
                        {ch.title}
                      </p>
                      <p class="text-xs text-text-muted">{ch.readingTime} min</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Reading Paths -->
    <section class="max-w-4xl mx-auto px-6 mb-20" data-animate>
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold mb-3">Choose Your Path</h2>
        <p class="text-text-muted">
          Four curated reading paths based on your role and experience level.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {READING_PATHS.map((rp) => (
          <a
            href={`/book/${CHAPTER_SLUG_MAP[rp.chapterIds[0]]}`}
            class="rounded-xl border border-border bg-surface-raised p-5 hover:border-primary/30 transition-colors group no-underline"
          >
            <div class="flex items-center justify-between mb-2">
              <h3 class="text-sm font-semibold group-hover:text-primary transition-colors">
                {rp.name}
              </h3>
              <span class="font-mono text-xs text-text-muted">
                {rp.chapterIds.length} chapters
              </span>
            </div>
            <p class="text-sm text-text-muted mb-3">{rp.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {rp.chapterIds.map((chId) => {
                const ch = CHAPTERS.find((c) => c.id === chId);
                return ch ? (
                  <span class="text-xs px-2 py-0.5 rounded-md bg-surface-overlay text-text-muted">
                    Ch. {ch.number}
                  </span>
                ) : null;
              })}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Reading Experience Preview -->
    <section class="max-w-5xl mx-auto px-6 mb-20" data-animate>
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold mb-3">The Reading Experience</h2>
        <p class="text-text-muted">
          A distraction-free reader with customizable fonts, themes, reading progress, and chapter navigation.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <BrowserFrame src="/screenshots/book-reader.png" alt="Book reader showing Chapter 1: Project Management with reading progress bar and Regenerate button" />
        <BrowserFrame src="/screenshots/book-toc.png" alt="Book table of contents sidebar with chapter list, reading paths, and completion checkmarks" />
        <BrowserFrame src="/screenshots/book-settings.png" alt="Book reading settings panel with font size, line height, font family, and theme selection" />
        <BrowserFrame src="/screenshots/book-chapter-nav.png" alt="Book chapter navigation with breadcrumb, reading time estimate, and section progress" />
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-4xl mx-auto px-6 text-center" data-animate>
      <div class="rounded-xl border border-border bg-surface-raised p-10">
        <h2 class="text-2xl font-bold mb-3">Ready to build AI-native?</h2>
        <p class="text-text-muted mb-6 max-w-lg mx-auto">
          Start with Chapter 1 and learn how to transform manual processes into
          autonomous AI agent operations.
        </p>
        <a
          href={`/book/${CHAPTER_SLUG_MAP['ch-1']}`}
          class="inline-flex items-center gap-2 bg-primary text-white font-medium px-6 py-3 rounded-lg hover:opacity-90 transition-opacity no-underline"
        >
          Begin Reading
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
