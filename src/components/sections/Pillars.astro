---
import SectionLabel from '../ui/SectionLabel.astro';
import PillarIcon from '../svg/PillarIcon.astro';
import { pillars } from '../../data/pillars';
---
<section class="py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div data-animate class="mb-12">
      <SectionLabel text="Differentiation" />
      <h2 class="mt-4">Five pillars.</h2>
    </div>

    <div data-animate-stagger>
      {pillars.map((pillar, i) => (
        <div
          data-animate
          class:list={[
            'grid md:grid-cols-[48px_1fr] gap-6 py-10 -mx-6 px-6 transition-colors duration-300 hover:bg-surface-overlay/50',
            i < pillars.length - 1 && 'border-b border-border',
          ]}
        >
          <div class="flex items-start">
            <PillarIcon icon={pillar.icon} class="w-12 h-12" />
          </div>
          <div>
            <div class="flex items-baseline gap-4 mb-2">
              <span class="font-mono text-xs text-amber opacity-80">
                0{pillar.number}
              </span>
              <h3 class="font-display text-xl">{pillar.name}</h3>
            </div>
            <p class="text-amber text-sm font-mono tracking-wide mb-3">
              {pillar.tagline}
            </p>
            <p class="text-text-muted text-sm leading-relaxed max-w-2xl">
              {pillar.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
