---
const slides = [
  { src: '/screenshots/home-list.png', alt: 'Workspace overview with active tasks and agent activity' },
  { src: '/screenshots/dashboard-list.png', alt: 'Dashboard analytics with project metrics' },
  { src: '/screenshots/dashboard-create-form-ai-assist.png', alt: 'AI Assist generating sub-tasks during task creation' },
  { src: '/screenshots/inbox-list.png', alt: 'Inbox with notifications and approval requests' },
  { src: '/screenshots/workflows-blueprints.png', alt: 'Blueprint catalog for reusable workflows' },
  { src: '/screenshots/profiles-list.png', alt: 'Agent profiles cards view' },
  { src: '/screenshots/cost-codex-claude-code.png', alt: 'Cost and usage breakdown for AI agents' },
];
---
<section class="relative min-h-[calc(100dvh-80px)] flex items-center px-6 overflow-hidden pt-20">
  <!-- Dual atmospheric glow -->
  <div class="absolute inset-0 -z-10 flex items-center justify-center pointer-events-none">
    <div class="absolute w-[800px] h-[800px] rounded-full bg-primary/[0.10] blur-[180px]"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full bg-primary/[0.15] blur-[100px]"></div>
  </div>

  <!-- Bottom gradient fade into next section -->
  <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none" style="background: linear-gradient(to bottom, transparent, var(--color-surface-raised));"></div>

  <!-- Two-column grid -->
  <div class="relative z-10 w-full max-w-7xl mx-auto grid lg:grid-cols-[1fr_1.2fr] gap-8 lg:gap-12 items-center py-12 lg:py-0">

    <!-- Left column: Content -->
    <div class="text-center lg:text-left" data-animate-stagger>

      <h1
        data-animate
        class="hero-gradient-text font-display text-[clamp(1.8rem,3.5vw,2.65rem)] font-bold leading-[1.15] mb-4"
      >
        Govern Your AI Agents.<br/>Operate With Oversight.
      </h1>

      <p
        data-animate
        class="text-[clamp(0.9rem,2vw,1.15rem)] text-text-muted leading-relaxed mb-6 mx-auto lg:mx-0"
      >
        Local-first agent operations with reusable profiles, workflow blueprints, scheduled runs, and human-in-the-loop oversight.
      </p>

      <!-- Terminal CTA -->
      <div data-animate class="my-8 max-w-md mx-auto lg:mx-0">
        <div class="relative border border-primary/30 rounded-lg primary-pulse overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2 border-b border-primary/10">
            <span class="font-mono text-[10px] uppercase tracking-widest text-text-muted">Terminal</span>
            <button
              id="hero-copy-btn"
              class="p-1 rounded text-text-muted/50 hover:text-text-muted transition-colors"
              aria-label="Copy to clipboard"
            >
              <svg id="hero-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <svg id="hero-check-icon" class="hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </button>
          </div>
          <div class="bg-surface-raised px-4 py-3">
            <pre class="font-mono text-lg sm:text-xl leading-relaxed text-text-muted"><span class="text-primary">$</span> <code id="hero-code">npx stagent</code><span class="hero-cursor">▌</span></pre>
          </div>
        </div>
      </div>

      <!-- Value proposition pills -->
      <div
        data-animate
        class="flex items-center justify-center lg:justify-start gap-2 flex-wrap mb-4"
      >
        <span class="font-mono text-[11px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-3 py-1">Local-First</span>
        <span class="font-mono text-[11px] tracking-wider text-primary border border-primary/20 bg-primary/5 rounded-full px-3 py-1">Human-in-the-Loop</span>
        <span class="font-mono text-[11px] tracking-wider text-success border border-success/20 bg-success/5 rounded-full px-3 py-1">Open Source</span>
      </div>

    </div>

    <!-- Right column: Carousel -->
    <div data-animate class="hero-carousel-wrapper" style="transition-delay: 200ms">
      <div class="hero-carousel rounded-xl overflow-hidden border border-border shadow-2xl shadow-primary/5">
        <!-- macOS title bar -->
        <div class="bg-surface-raised border-b border-border px-4 py-3 flex items-center gap-2">
          <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
          <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
          <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
        </div>
        <!-- Slide stack -->
        <div class="hero-slides relative overflow-hidden">
          {slides.map((slide, i) => (
            <img
              src={slide.src}
              alt={slide.alt}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding={i === 0 ? 'sync' : 'async'}
              class:list={[
                'hero-slide w-full block',
                i === 0 ? 'relative' : 'absolute inset-0',
              ]}
              data-slide={i}
            />
          ))}
        </div>
        <!-- Dot indicators -->
        <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex items-center gap-2 z-10">
          {slides.map((_, i) => (
            <button
              class:list={[
                'hero-dot w-2 h-2 rounded-full transition-all duration-300',
                i === 0 ? 'bg-primary w-4' : 'bg-text-muted/30 hover:bg-text-muted/50',
              ]}
              data-dot={i}
              aria-label={`Show slide ${i + 1}`}
            />
          ))}
        </div>
      </div>
    </div>

  </div>
</section>


<style>
  /* ── Gradient text ── */
  .hero-gradient-text {
    background: linear-gradient(135deg, oklch(0.78 0.12 230), var(--color-primary), oklch(0.58 0.18 280));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Blinking cursor ── */
  .hero-cursor {
    animation: hero-blink 1s step-end infinite;
    color: var(--color-primary);
  }
  @keyframes hero-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ── Carousel wrapper - relative for dot positioning ── */
  .hero-carousel-wrapper {
    position: relative;
  }
  .hero-carousel {
    position: relative;
  }

  /* ── Slide base ── */
  .hero-slide {
    opacity: 0;
    transform: translateX(100%);
    image-rendering: -webkit-optimize-contrast;
  }
  .hero-slide.active {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Zoom on hover ── */
  .hero-slide.active {
    transition: transform 0.6s ease-in-out;
  }
  .hero-slide.zoomed {
    transform: scale(1.5);
  }

  /* ── Slide transitions ── */
  @keyframes hero-slide-in {
    from { transform: translateX(100%); }
    to   { transform: translateX(0); }
  }
  @keyframes hero-slide-out {
    from { transform: translateX(0); }
    to   { transform: translateX(-100%); }
  }
  .hero-slide.sliding-in {
    opacity: 1;
    animation: hero-slide-in 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  .hero-slide.sliding-out {
    opacity: 1;
    animation: hero-slide-out 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  /* ── Dot active state (managed by JS) ── */
  .hero-dot.active {
    background: var(--color-primary);
    width: 1rem;
  }

  /* ── Small screens: single static image ── */
  @media (max-width: 639px) {
    .hero-slide {
      animation: none !important;
      opacity: 0;
      transform: none;
    }
    .hero-slide:first-child {
      opacity: 1;
    }
    .hero-slide:not(:first-child) {
      display: none;
    }
    .hero-dot {
      display: none;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .hero-slide {
      animation: none !important;
      opacity: 0;
      transform: none;
    }
    .hero-slide:first-child {
      opacity: 1;
    }
    .hero-cursor {
      animation: none;
    }
  }
</style>

<script>
  function initHero() {
    // ── Copy button ──
    document.getElementById('hero-copy-btn')?.addEventListener('click', async () => {
      const code = document.getElementById('hero-code')?.textContent ?? '';
      await navigator.clipboard.writeText(code);
      const copyIcon = document.getElementById('hero-copy-icon');
      const checkIcon = document.getElementById('hero-check-icon');
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
      }, 2000);
    });

    // ── Carousel slide manager ──
    const slides = document.querySelectorAll<HTMLImageElement>('.hero-slide');
    const dots = document.querySelectorAll<HTMLButtonElement>('.hero-dot');
    const carousel = document.querySelector('.hero-carousel');
    if (slides.length === 0 || dots.length === 0) return;

    // Skip animation on mobile or reduced motion
    const isMobile = window.matchMedia('(max-width: 639px)').matches;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (isMobile || prefersReduced) {
      slides[0]?.classList.add('active');
      return;
    }

    let currentIndex = 0;
    let isTransitioning = false;
    let isPaused = false;
    let autoplayTimer: ReturnType<typeof setTimeout> | null = null;

    const SLIDE_INTERVAL = 4000;
    const SLIDE_DURATION = 600;

    function updateDots(index: number) {
      dots.forEach((d, i) => {
        d.classList.toggle('active', i === index);
        d.classList.toggle('bg-primary', i === index);
        d.classList.toggle('w-4', i === index);
        d.classList.toggle('bg-text-muted/30', i !== index);
        d.classList.toggle('w-2', i !== index);
      });
    }

    function clearSlideClasses(slide: HTMLImageElement) {
      slide.classList.remove('active', 'zoomed', 'sliding-in', 'sliding-out');
      slide.style.animation = '';
    }

    function scheduleNext() {
      if (autoplayTimer) clearTimeout(autoplayTimer);
      autoplayTimer = setTimeout(() => {
        if (isPaused) return; // Will be rescheduled on mouseleave
        transitionToNext();
      }, SLIDE_INTERVAL);
    }

    function jumpToSlide(index: number) {
      if (autoplayTimer) clearTimeout(autoplayTimer);
      isTransitioning = false;

      slides.forEach(s => clearSlideClasses(s as HTMLImageElement));

      currentIndex = index;
      slides[currentIndex]?.classList.add('active');
      updateDots(currentIndex);

      scheduleNext();
    }

    function transitionToNext() {
      if (isTransitioning) return;
      isTransitioning = true;

      const nextIndex = (currentIndex + 1) % slides.length;
      const current = slides[currentIndex] as HTMLImageElement;
      const next = slides[nextIndex] as HTMLImageElement;

      // Remove zoom if hovering, then slide out
      current.classList.remove('zoomed');
      current.classList.add('sliding-out');
      next.classList.add('sliding-in');
      updateDots(nextIndex);

      autoplayTimer = setTimeout(() => {
        clearSlideClasses(current);
        next.classList.remove('sliding-in');
        next.classList.add('active');
        // Re-apply zoom if mouse is still over carousel
        if (isPaused) next.classList.add('zoomed');

        currentIndex = nextIndex;
        isTransitioning = false;

        scheduleNext();
      }, SLIDE_DURATION);
    }

    // ── Dot clicks ──
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => jumpToSlide(i));
    });

    // ── Hover: zoom-pulse (zoom in, auto-zoom-out after 300ms) ──
    let zoomTimeout: ReturnType<typeof setTimeout> | null = null;
    carousel?.addEventListener('mouseenter', () => {
      isPaused = true;
      const active = slides[currentIndex];
      if (active && !isTransitioning) {
        active.classList.add('zoomed');
        zoomTimeout = setTimeout(() => {
          active.classList.remove('zoomed');
          zoomTimeout = null;
        }, 1800);
      }
    });
    carousel?.addEventListener('mouseleave', () => {
      isPaused = false;
      if (zoomTimeout) { clearTimeout(zoomTimeout); zoomTimeout = null; }
      const active = slides[currentIndex];
      if (active) active.classList.remove('zoomed');
      // Resume autoplay
      scheduleNext();
    });

    // ── Initialize first slide and start ──
    slides[0]?.classList.add('active');
    updateDots(0);
    scheduleNext();
  }

  // Init on load and on Astro view transitions
  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>
