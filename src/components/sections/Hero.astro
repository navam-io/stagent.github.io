---
import BrowserFrame from '../ui/BrowserFrame.astro';
---
<section class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden pt-24 pb-16">
  <!-- Perspective grid -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="hero-grid"></div>
  </div>

  <!-- Dual atmospheric glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="absolute w-[800px] h-[800px] rounded-full bg-primary/[0.10] blur-[180px]"></div>
    <div class="absolute w-[400px] h-[400px] rounded-full bg-primary/[0.15] blur-[100px]"></div>
  </div>

  <!-- Bottom gradient fade into next section (bg-surface-raised) -->
  <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none" style="background: linear-gradient(to bottom, transparent, var(--color-surface-raised));"></div>

  <!-- Content -->
  <div class="relative z-10 text-center max-w-4xl">
    <h1
      data-animate
      class="font-mono text-[clamp(2.2rem,10vw,7rem)] tracking-[0.2em] sm:tracking-[0.5em] font-normal mb-6 text-text whitespace-nowrap text-center"
      style="padding-left: 0.2em;"
    >
      STAGENT
    </h1>

    <p
      data-animate
      class="text-[clamp(0.95rem,2.5vw,1.5rem)] text-text-muted leading-relaxed mb-8 max-w-2xl mx-auto"
      style="transition-delay: 120ms"
    >
      Governed AI agent operations with reusable profiles, workflow blueprints, scheduled runs, and local-first oversight
    </p>

    <!-- Stats bar -->
    <div
      data-animate
      class="flex items-center justify-center gap-3 sm:gap-8 mb-10 flex-wrap font-mono text-xs tracking-widest text-text-muted"
      style="transition-delay: 200ms"
    >
      <span>Profiles &amp; Policies</span>
      <span class="text-border">·</span>
      <span>Blueprints &amp; Schedules</span>
      <span class="text-border">·</span>
      <span>Open Source</span>
    </div>

    <p
      data-animate
      class="font-mono text-xs tracking-[0.28em] uppercase text-primary mb-5"
      style="transition-delay: 260ms"
    >
      Get started
    </p>

    <!-- CTA -->
    <div data-animate class="mb-10 max-w-xl mx-auto" style="transition-delay: 300ms">
      <!-- Download card -->
      <div class="border border-border rounded-md px-6 py-4 flex flex-col items-center justify-center">
        <span class="font-mono text-xs uppercase tracking-widest text-text-muted mb-4">macOS Desktop App</span>
        <a
          href="https://github.com/navam-io/stagent/releases/latest/download/Stagent.dmg"
          class="hero-download-btn inline-flex items-center justify-center gap-2 bg-primary text-surface font-mono text-sm tracking-wider uppercase w-full py-3 rounded-md hover:bg-primary/90 transition-all mb-3"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download
        </a>
        <span class="font-mono text-xs text-text-muted">Latest release · DMG</span>
      </div>

      <!-- OR divider -->
      <div class="flex items-center gap-4 my-4">
        <div class="flex-1 h-px bg-border"></div>
        <span class="font-mono text-xs text-text-muted">OR</span>
        <div class="flex-1 h-px bg-border"></div>
      </div>

      <!-- Run Local Web App card -->
      <div class="relative border border-border rounded-md px-6 py-4 flex flex-col justify-center">
        <span class="font-mono text-xs uppercase tracking-widest text-text-muted mb-4 text-center">Run Local Web App</span>
        <button
          id="hero-copy-btn"
          class="absolute top-3 right-3 p-1.5 rounded text-text-muted/50 hover:text-text-muted transition-colors"
          aria-label="Copy to clipboard"
        >
          <svg id="hero-copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <svg id="hero-check-icon" class="hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </button>
        <pre class="rounded-md bg-surface-raised px-4 py-3 text-left font-mono text-sm leading-relaxed text-text-muted"><code id="hero-code">git clone https://github.com/navam-io/stagent.git
cd stagent && npm install
npm run dev</code></pre>
      </div>
    </div>

    <div data-animate class="mb-16" style="transition-delay: 340ms">
      <a
        href="/docs"
        class="font-mono text-xs tracking-[0.2em] uppercase text-text-muted border border-border px-8 py-3 hover:border-primary hover:text-primary transition-colors rounded-md"
      >
        View Docs
      </a>
    </div>

    <!-- Hero screenshot -->
    <div data-animate style="transition-delay: 400ms" class="max-w-4xl mx-auto">
      <BrowserFrame
        src="/screenshots/home-list.png"
        alt="Stagent home workspace showing active tasks, pending reviews, project metrics, and live agent activity"
        perspective={true}
      />
    </div>
  </div>

  <!-- Scroll chevron -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </div>
</section>


<style>
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        90deg,
        var(--color-border) 0 1px,
        transparent 1px 60px
      ),
      repeating-linear-gradient(
        0deg,
        var(--color-border) 0 1px,
        transparent 1px 60px
      );
    opacity: 0.2;
    transform: perspective(600px) rotateX(55deg);
    transform-origin: center top;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 30%, black 20%, transparent 70%);
  }

  .hero-download-btn {
    box-shadow: 0 0 20px var(--color-primary-glow), 0 0 40px var(--color-primary-dim);
  }
  .hero-download-btn:hover {
    box-shadow: 0 0 25px var(--color-primary-glow), 0 0 50px var(--color-primary-glow);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-grid {
      transform: none;
    }
  }
</style>

<script>
  document.getElementById('hero-copy-btn')?.addEventListener('click', async () => {
    const code = document.getElementById('hero-code')?.textContent ?? '';
    await navigator.clipboard.writeText(code);
    const copyIcon = document.getElementById('hero-copy-icon');
    const checkIcon = document.getElementById('hero-check-icon');
    copyIcon?.classList.add('hidden');
    checkIcon?.classList.remove('hidden');
    setTimeout(() => {
      copyIcon?.classList.remove('hidden');
      checkIcon?.classList.add('hidden');
    }, 2000);
  });
</script>
