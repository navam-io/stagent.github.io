---
import WaitlistForm from '../ui/WaitlistForm.astro';
import BrowserFrame from '../ui/BrowserFrame.astro';
---
<section class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden pt-24 pb-16">
  <!-- Atmospheric glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="absolute w-[600px] h-[600px] rounded-full bg-primary/[0.06] blur-[150px]"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center max-w-4xl">
    <h1
      data-animate
      class="font-mono text-[clamp(4rem,10vw,7rem)] tracking-[0.5em] font-normal mb-6 text-text whitespace-nowrap text-center"
      style="padding-left: 0.5em;"
    >
      STAGENT
    </h1>

    <p
      data-animate
      class="text-[clamp(1.1rem,2.5vw,1.5rem)] text-text-muted leading-relaxed mb-8 max-w-2xl mx-auto"
      style="transition-delay: 120ms"
    >
      AI-powered task management where Claude agents execute tasks with human-in-the-loop oversight
    </p>

    <!-- Stats bar -->
    <div
      data-animate
      class="flex items-center justify-center gap-4 sm:gap-8 mb-10 font-mono text-xs tracking-widest text-text-muted"
      style="transition-delay: 200ms"
    >
      <span>18 Features Shipped</span>
      <span class="text-border">·</span>
      <span>7 Sprints</span>
      <span class="text-border">·</span>
      <span>Open Source</span>
    </div>

    <!-- CTAs -->
    <div data-animate class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16" style="transition-delay: 300ms">
      <div class="w-full sm:w-auto">
        <WaitlistForm variant="hero" id="hero-waitlist" />
      </div>
      <a
        href="/docs"
        class="font-mono text-xs tracking-[0.2em] uppercase text-text-muted border border-border px-8 py-3 hover:border-primary hover:text-primary transition-colors rounded-md"
      >
        View Docs
      </a>
    </div>

    <!-- Hero screenshot -->
    <div data-animate style="transition-delay: 400ms" class="max-w-4xl mx-auto">
      <BrowserFrame
        src="/screenshots/home-dashboard.png"
        alt="Stagent dashboard showing project overview with task statistics"
        perspective={true}
      />
    </div>
  </div>

  <!-- Scroll chevron -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </div>
</section>
