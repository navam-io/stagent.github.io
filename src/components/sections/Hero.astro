---
import DagSymbol from '../svg/DagSymbol.astro';
---
<section class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden">
  <!-- Atmospheric glow -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="absolute w-[500px] h-[500px] rounded-full bg-amber/[0.04] blur-[120px]"></div>
    <DagSymbol class="w-[600px] h-[600px] text-amber opacity-[0.04]" />
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center max-w-4xl">
    <h1
      data-animate
      class="font-mono text-[clamp(4rem,10vw,7rem)] tracking-[0.5em] font-normal mb-8 text-text whitespace-nowrap text-center"
      style="padding-left: 0.5em;"
    >
      STAGENT
    </h1>

    <p
      data-animate
      class="font-mono text-[clamp(1.25rem,3vw,2rem)] text-text leading-relaxed mb-12"
      style="transition-delay: 120ms"
    >
      The world of agents is your stage
    </p>

    <p
      data-animate
      class="text-text-muted text-sm max-w-lg mx-auto leading-relaxed mb-14"
      style="transition-delay: 240ms"
    >
      A desktop-native, open-source harness that turns high-level goals into
      observable, long-running agent workflows — across any model, any tool,
      any timeline.
    </p>

    <div data-animate style="transition-delay: 360ms">
      <a
        href="/research"
        class="inline-block font-mono text-xs tracking-[0.2em] uppercase text-amber border border-amber/40 px-8 py-3 hover:bg-amber/10 transition-colors"
      >
        Read the Research Paper
      </a>
    </div>
  </div>

  <!-- Scroll chevron -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M6 9l6 6 6-6" />
    </svg>
  </div>
</section>
