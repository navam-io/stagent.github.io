---
import SectionLabel from '../ui/SectionLabel.astro';

const cards = [
  {
    title: 'Home Workspace',
    description: 'See running work, pending approvals, active projects, and live agent activity from a single starting point.',
    screenshot: '/screenshots/home-list.png',
    alt: 'Home workspace showing summary metrics, tasks needing attention, and live agent activity',
  },
  {
    title: 'Reusable Profiles',
    description: 'Specialist agent profiles bundle instructions, tool policies, and runtime tuning into reusable operational templates.',
    screenshot: '/screenshots/profiles-list.png',
    alt: 'Profiles catalog showing work and personal agent profiles',
  },
  {
    title: 'Workflow Blueprints',
    description: 'Start from proven multi-step blueprints instead of rebuilding orchestration logic for every repeatable process.',
    screenshot: '/screenshots/workflows-blueprints.png',
    alt: 'Workflow blueprint gallery with reusable templates',
  },
  {
    title: 'Governed Execution',
    description: 'Review permissions with allow once, always allow, and deny controls while keeping a clear audit trail of decisions.',
    screenshot: '/screenshots/inbox-permissions.png',
    alt: 'Inbox permissions tab showing approval controls for agent tool requests',
  },
];
---
<section class="py-24 px-6 bg-surface-raised">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <SectionLabel text="Product" />
      <h2 data-animate class="mt-4">Everything you need to manage AI agents</h2>
    </div>

    <div data-animate-stagger class="grid md:grid-cols-2 xl:grid-cols-4 gap-8">
      {cards.map(({ title, description, screenshot, alt }) => (
        <div data-animate class="group">
          <div class="img-reveal mb-6 overflow-hidden rounded-lg border border-border">
            <img
              src={screenshot}
              alt={alt}
              loading="lazy"
              decoding="async"
              class="w-full block group-hover:scale-[1.02] transition-transform duration-300"
            />
          </div>
          <h3 class="text-lg font-semibold mb-2">{title}</h3>
          <p class="text-text-muted text-sm leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
