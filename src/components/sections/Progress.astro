---
import SectionLabel from '../ui/SectionLabel.astro';

const stats = [
  {
    value: '15',
    label: 'Product Surfaces',
    detail: 'Home, dashboard, projects, workflows, documents, inbox, monitor, profiles, schedules, costs, chat, environment, playbook, settings, and command palette.',
  },
  {
    value: '6',
    label: 'Workflow Patterns',
    detail: 'Sequence, planner-executor, checkpoint, fork/join parallel, autonomous loop, and multi-agent swarm.',
  },
  {
    value: '3',
    label: 'Authentication Modes',
    detail: 'Connect with Claude OAuth, Claude API key, or OpenAI API key for dual-runtime execution.',
  },
  {
    value: 'Local-first',
    label: 'Operating Model',
    detail: 'SQLite-backed control plane, local files, and approvals that stay close to the work.',
  },
];
---
<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <SectionLabel text="Progress" />
      <h2 data-animate class="mt-4">Shipped, not slideware</h2>
    </div>

    <div data-animate-stagger class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20">
      {stats.map(({ value, label, detail }) => (
        <div data-animate class="rounded-xl border border-border bg-surface-raised p-6 text-center">
          <div class="text-2xl md:text-3xl font-bold text-primary font-mono">
            {value}
          </div>
          <div class="text-text-muted text-sm mt-2 font-mono tracking-widest uppercase">{label}</div>
          <p class="text-xs text-text-muted leading-relaxed mt-4">{detail}</p>
        </div>
      ))}
    </div>
    <div data-animate class="max-w-3xl mx-auto text-center">
      <p class="text-text-muted leading-relaxed">
        68 shipped features across 15 surfaces. The product operates as a full coordination workspace with 21 reusable agent profiles, 6 workflow patterns, scheduled runs, governed permissions, document-linked execution, cross-runtime cost governance, conversational AI with multi-provider model selection, environment scanning with health scoring, and a built-in playbook for guided adoption.
      </p>
    </div>
  </div>
</section>
