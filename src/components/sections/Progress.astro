---
import SectionLabel from '../ui/SectionLabel.astro';

const stats = [
  {
    value: '10',
    label: 'Product Surfaces',
    detail: 'Home, dashboard, projects, workflows, documents, inbox, monitor, profiles, schedules, and settings.',
  },
  {
    value: '3',
    label: 'Workflow Patterns',
    detail: 'Sequence, planner-executor, and human-in-the-loop checkpoint orchestration.',
  },
  {
    value: '2',
    label: 'Authentication Modes',
    detail: 'Connect with OAuth or a direct API key depending on how your team deploys Claude.',
  },
  {
    value: 'Local-first',
    label: 'Operating Model',
    detail: 'SQLite-backed control plane, local files, and approvals that stay close to the work.',
  },
];
---
<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <SectionLabel text="Progress" />
      <h2 data-animate class="mt-4">Shipped, not slideware</h2>
    </div>

    <div data-animate-stagger class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20">
      {stats.map(({ value, label, detail }) => (
        <div data-animate class="rounded-xl border border-border bg-surface-raised p-6 text-center">
          <div class="text-2xl md:text-3xl font-bold text-primary font-mono">
            {value}
          </div>
          <div class="text-text-muted text-sm mt-2 font-mono tracking-widest uppercase">{label}</div>
          <p class="text-xs text-text-muted leading-relaxed mt-4">{detail}</p>
        </div>
      ))}
    </div>
    <div data-animate class="max-w-3xl mx-auto text-center">
      <p class="text-text-muted leading-relaxed">
        The current browser product now operates as a full coordination workspace with reusable agent profiles, workflow blueprints, scheduled runs, governed permissions, and document-linked execution.
      </p>
    </div>
  </div>
</section>
