---
import SectionLabel from '../ui/SectionLabel.astro';
import BrowserFrame from '../ui/BrowserFrame.astro';

const features = [
  {
    title: 'Workspace Overview',
    description: 'Open Stagent to a concise operational brief: running tasks, pending approvals, active projects, and live agent activity in one place.',
    bullets: ['Needs-attention queue', 'Workspace-level metrics', 'Live agent activity panel'],
    screenshot: '/screenshots/home-list.png',
    alt: 'Home workspace showing summary metrics, tasks needing attention, and live activity',
  },
  {
    title: 'Execution Dashboard',
    description: 'Run the day-to-day queue from a status board that keeps planned, queued, running, completed, and failed work visible across projects.',
    bullets: ['Project and status filters', 'Column-based execution states', 'Inline task creation'],
    screenshot: '/screenshots/dashboard-list.png',
    alt: 'Dashboard board showing tasks organized by status across multiple projects',
  },
  {
    title: 'Project Portfolio',
    description: 'Track parallel initiatives as projects with clean summaries, attached context, and a dedicated execution view for each body of work.',
    bullets: ['Portfolio card list', 'Status-aware progress', 'Scoped work context'],
    screenshot: '/screenshots/projects-list.png',
    alt: 'Projects list showing active and completed projects',
  },
  {
    title: 'Project Detail',
    description: 'Drill into a project to see task distribution, recent completions, and the exact queue that is driving the initiative forward.',
    bullets: ['Status summary cards', 'Completion trend strip', 'Project-scoped task list'],
    screenshot: '/screenshots/projects-detail.png',
    alt: 'Project detail view showing status summary cards and task list',
  },
  {
    title: 'Workflow Library',
    description: 'Manage multi-step workflows with clear lifecycle state, pattern labels, and reusable orchestration for repeated operational jobs.',
    bullets: ['Sequence and checkpoint patterns', 'Project-aware workflow records', 'Pause, resume, and duplicate controls'],
    screenshot: '/screenshots/workflows-list.png',
    alt: 'Workflows list showing active, completed, and paused workflows',
  },
  {
    title: 'Blueprint Catalog',
    description: 'Start from preconfigured blueprints for code review, research, planning, documentation, and personal workflows instead of creating flows from scratch.',
    bullets: ['Work and personal templates', 'Difficulty labels', 'Search and filter controls'],
    screenshot: '/screenshots/workflows-blueprints.png',
    alt: 'Workflow blueprint gallery with work and personal templates',
  },
  {
    title: 'Document Operations',
    description: 'Store uploaded files in searchable table and grid views, then inspect extracted content and project/task links without leaving the workspace.',
    bullets: ['Table and grid browsing', 'Extraction status visibility', 'Linked task and project metadata'],
    screenshot: '/screenshots/documents-list.png',
    alt: 'Documents list showing uploaded files with task, project, and extraction status',
  },
  {
    title: 'Agent Profiles',
    description: 'Profiles make agent behavior explicit through instructions, tool policies, output formats, and tuning controls that operators can inspect and reuse.',
    bullets: ['Curated role catalog', 'Policy chips per profile', 'Embedded SKILL.md instructions'],
    screenshot: '/screenshots/profiles-detail.png',
    alt: 'Profile detail showing instructions, configuration, and tool policies',
  },
  {
    title: 'Scheduled Runs',
    description: 'Turn repeatable prompts into recurring or one-shot schedules with explicit timing, firing limits, expiry windows, and agent-profile selection.',
    bullets: ['Recurring and one-shot schedules', 'Pause and resume controls', 'Next-fire visibility'],
    screenshot: '/screenshots/schedules-detail.png',
    alt: 'Schedule detail showing prompt, next fire time, and firing history',
  },
  {
    title: 'Human Oversight',
    description: 'The inbox surfaces agent messages, completions, failures, and permission requests with direct approval actions for governed execution.',
    bullets: ['Allow once / always allow / deny', 'Unread, permission, and message tabs', 'Decision history'],
    screenshot: '/screenshots/inbox-permissions.png',
    alt: 'Permissions inbox showing approval actions for a tool request',
  },
  {
    title: 'Live Monitoring',
    description: 'Follow live execution through log streaming, active-agent metrics, success-rate signals, and task/event filters built for debugging and oversight.',
    bullets: ['Auto-refreshing log stream', 'Workspace health cards', 'Task and event filtering'],
    screenshot: '/screenshots/monitor-list.png',
    alt: 'Monitoring view showing active agents and log stream',
  },
];
---
<section id="features" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <SectionLabel text="Features" />
      <h2 data-animate class="mt-4">Built for real work</h2>
    </div>

    <div class="flex flex-col gap-24">
      {features.map(({ title, description, bullets, screenshot, alt }, i) => (
        <div
          data-animate
          class:list={[
            "grid md:grid-cols-2 gap-12 items-center",
            i % 2 === 1 && "md:[direction:rtl] md:[&>*]:![direction:ltr]"
          ]}
        >
          <div>
            <h3 class="text-xl font-semibold mb-4">{title}</h3>
            <p class="text-text-muted leading-relaxed mb-6">{description}</p>
            <ul class="space-y-2">
              {bullets.map((bullet) => (
                <li class="flex items-start gap-3 text-sm text-text-muted">
                  <svg class="w-4 h-4 mt-0.5 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {bullet}
                </li>
              ))}
            </ul>
          </div>
          <div class="img-reveal">
            <BrowserFrame src={screenshot} alt={alt} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
