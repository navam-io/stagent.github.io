---
import SectionLabel from '../ui/SectionLabel.astro';
import ProtocolStack from '../svg/ProtocolStack.astro';
import { protocols } from '../../data/protocols';

const techBadges = [
  'Rust', 'TypeScript', 'Tauri', 'React', 'SQLite',
  'WASM', 'MCP', 'A2A', 'WebMCP', 'CDP', 'Ollama',
];
---
<section class="py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div data-animate class="mb-16">
      <SectionLabel text="Architecture" />
      <h2 class="mt-4">Rust + TypeScript hybrid.</h2>
    </div>

    <div class="grid lg:grid-cols-[1fr_360px] gap-16 items-start">
      <div data-animate-stagger class="space-y-6">
        <p data-animate class="text-text-muted leading-relaxed">
          Rust owns the system — desktop shell, WASM sandboxing, persistent
          storage, IPC. TypeScript owns the intelligence — LLM interaction,
          agent logic, tool execution, protocol communication. Neither crosses
          into the other's domain.
        </p>
        <p data-animate class="text-text-muted leading-relaxed">
          The boundary is architectural, not arbitrary. Rust's safety and
          performance handle the system-level concerns that agents must never
          compromise. TypeScript's ecosystem breadth provides access to every
          major LLM SDK and the growing MCP connector ecosystem.
        </p>
        <p data-animate class="text-text leading-relaxed">
          Six protocols form the communication backbone — from agent-to-tool
          (MCP) to agent-to-agent (A2A) to agent-to-website (WebMCP), with
          graceful fallback at every layer.
        </p>
      </div>

      <!-- Protocol stack SVG -->
      <div data-animate class="hidden lg:block" style="transition-delay: 200ms">
        <ProtocolStack protocols={protocols} class="w-full text-text" />
      </div>
    </div>

    <!-- Tech badges -->
    <div data-animate class="mt-16 flex flex-wrap gap-3" style="transition-delay: 100ms">
      {techBadges.map((badge) => (
        <span class="font-mono text-[0.625rem] tracking-widest uppercase text-text-muted border border-border px-3 py-1.5">
          {badge}
        </span>
      ))}
    </div>
  </div>
</section>
