---
import SectionLabel from '../ui/SectionLabel.astro';
import SystemArchitecture from '../svg/SystemArchitecture.astro';
import GovernanceFlow from '../svg/GovernanceFlow.astro';

const techStack = [
  'Next.js 16', 'React 19', 'TypeScript', 'Tailwind v4',
  'shadcn/ui', 'SQLite', 'Drizzle ORM', 'Claude Agent SDK', 'Codex App Server',
];
---
<section class="py-24 px-6 bg-surface-raised">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <SectionLabel text="Architecture" />
      <h2 data-animate class="mt-4">Four layers, one mission</h2>
      <p data-animate class="text-text-muted mt-4 max-w-xl mx-auto" style="transition-delay: 100ms">
        Every agent action flows through human oversight. The coordination layer ensures nothing happens without your approval.
      </p>
    </div>

    <!-- System Architecture SVG -->
    <div data-animate class="mb-20 overflow-x-auto" style="transition-delay: 200ms">
      <SystemArchitecture />
    </div>

    <!-- Governance Flow -->
    <div class="mb-20">
      <h3 data-animate class="text-center text-lg font-semibold mb-8">Human-in-the-loop governance</h3>
      <div data-animate class="overflow-x-auto" style="transition-delay: 100ms">
        <GovernanceFlow />
      </div>
    </div>

    <!-- Tech Stack Badges -->
    <div data-animate class="text-center" style="transition-delay: 300ms">
      <p class="font-mono text-xs tracking-widest text-text-muted uppercase mb-6">Built with</p>
      <div class="flex flex-wrap justify-center gap-3">
        {techStack.map((tech) => (
          <span class="font-mono text-xs px-4 py-2 bg-surface-raised border border-border rounded-md text-text-muted hover:text-primary hover:border-primary/30 transition-colors">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
