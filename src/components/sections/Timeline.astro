---
import SectionLabel from '../ui/SectionLabel.astro';
import WaveLine from '../svg/WaveLine.astro';
import { timeline } from '../../data/timeline';

const metrics = [
  { value: '270K+', label: 'Lines of Code', countValue: 270, suffix: 'K+' },
  { value: '30+', label: 'AI Agents Built', countValue: 30, suffix: '+' },
  { value: '8', label: 'Production Systems', countValue: 8, suffix: '' },
  { value: '18+', label: 'Projects Shipped', countValue: 18, suffix: '+' },
  { value: '68+', label: 'Blog Articles', countValue: 68, suffix: '+' },
];
---
<section class="relative py-32 px-6 overflow-hidden bg-surface-raised">
  <!-- Wave background -->
  <div class="absolute inset-0 flex items-center pointer-events-none opacity-50">
    <WaveLine class="w-full text-text" />
  </div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <div data-animate class="mb-12">
      <SectionLabel text="Portfolio" />
      <h2 class="mt-4">Nine projects across five technology waves.</h2>
    </div>

    <!-- Metrics bar -->
    <div data-animate class="grid grid-cols-2 md:grid-cols-5 gap-6 mb-20" id="metrics-bar">
      {metrics.map((m) => (
        <div class="text-center">
          <div
            class="font-display text-3xl text-amber mb-1"
            data-count-to={m.countValue}
            data-count-suffix={m.suffix}
          >0{m.suffix}</div>
          <div class="font-mono text-[0.625rem] tracking-widest uppercase text-text-muted">
            {m.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Timeline -->
    <div data-animate-stagger class="relative">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px bg-border"></div>

      {timeline.map((item) => (
        <div
          data-animate
          class:list={[
            'relative pl-12 md:pl-20 pb-10',
            item.isCurrent && 'pl-12 md:pl-20',
          ]}
        >
          <!-- Dot -->
          <div
            class:list={[
              'absolute left-2.5 md:left-6.5 top-1 w-3 h-3 rounded-full border-2',
              item.isCurrent
                ? 'bg-amber border-amber amber-pulse'
                : 'bg-surface border-border',
            ]}
          ></div>

          <div
            class:list={[
              'p-5',
              item.isCurrent
                ? 'border border-amber/40 bg-amber/[0.03]'
                : 'border border-transparent',
            ]}
          >
            <div class="flex flex-wrap items-baseline gap-3 mb-1">
              <span class="font-mono text-xs text-text-muted">{item.year}</span>
              <h3 class:list={[
                'font-display text-lg',
                item.isCurrent ? 'text-amber' : 'text-text',
              ]}>
                {item.project}
              </h3>
              <span class="font-mono text-[0.6rem] tracking-widest uppercase text-text-muted">
                {item.techWave}
              </span>
            </div>
            <p class="text-text-muted text-sm">{item.role}</p>
            <p class="font-mono text-xs text-text-muted mt-1">{item.stats}</p>
            {item.tech && item.tech.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-2">
                {item.tech.map((t) => (
                  <span class="font-mono text-[0.55rem] tracking-wide px-1.5 py-0.5 border border-border text-text-muted">
                    {t}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initCounterAnimation() {
    const metricsBar = document.getElementById('metrics-bar');
    if (!metricsBar) return;

    const counters = metricsBar.querySelectorAll('[data-count-to]');
    let animated = false;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !animated) {
            animated = true;
            counters.forEach((el) => {
              const target = parseInt(el.getAttribute('data-count-to') || '0', 10);
              const suffix = el.getAttribute('data-count-suffix') || '';
              const duration = 1200;
              const start = performance.now();

              function update(now: number) {
                const elapsed = now - start;
                const t = Math.min(elapsed / duration, 1);
                // Ease-out cubic
                const eased = 1 - Math.pow(1 - t, 3);
                const current = Math.round(eased * target);
                el.textContent = current + suffix;

                if (t < 1) {
                  requestAnimationFrame(update);
                }
              }

              requestAnimationFrame(update);
            });
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(metricsBar);
  }

  initCounterAnimation();
  document.addEventListener('astro:after-swap', initCounterAnimation);
</script>
