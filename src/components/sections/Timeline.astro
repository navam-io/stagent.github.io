---
import SectionLabel from '../ui/SectionLabel.astro';
import WaveLine from '../svg/WaveLine.astro';
import { timeline } from '../../data/timeline';

const metrics = [
  { value: '45K+', label: 'Lines of Code' },
  { value: '27+', label: 'AI Agents Built' },
  { value: '5', label: 'Production Systems' },
  { value: '18+', label: 'Projects Shipped' },
];
---
<section class="relative py-32 px-6 overflow-hidden">
  <!-- Wave background -->
  <div class="absolute inset-0 flex items-center pointer-events-none opacity-50">
    <WaveLine class="w-full text-text" />
  </div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <div data-animate class="mb-16">
      <SectionLabel text="Portfolio" />
      <h2 class="mt-4">Built across three technology waves.</h2>
    </div>

    <!-- Metrics bar -->
    <div data-animate class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-20">
      {metrics.map((m) => (
        <div class="text-center">
          <div class="font-display text-3xl text-amber mb-1">{m.value}</div>
          <div class="font-mono text-[0.625rem] tracking-widest uppercase text-text-muted">
            {m.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Timeline -->
    <div data-animate-stagger class="relative">
      <!-- Vertical line -->
      <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px bg-border"></div>

      {timeline.map((item) => (
        <div
          data-animate
          class:list={[
            'relative pl-12 md:pl-20 pb-10',
            item.isCurrent && 'pl-12 md:pl-20',
          ]}
        >
          <!-- Dot -->
          <div
            class:list={[
              'absolute left-2.5 md:left-6.5 top-1 w-3 h-3 rounded-full border-2',
              item.isCurrent
                ? 'bg-amber border-amber amber-pulse'
                : 'bg-surface border-border',
            ]}
          ></div>

          <div
            class:list={[
              'p-5',
              item.isCurrent
                ? 'border border-amber/30 bg-amber/[0.03]'
                : 'border border-transparent',
            ]}
          >
            <div class="flex flex-wrap items-baseline gap-3 mb-1">
              <span class="font-mono text-xs text-text-muted">{item.year}</span>
              <h3 class:list={[
                'font-display text-lg',
                item.isCurrent ? 'text-amber' : 'text-text',
              ]}>
                {item.project}
              </h3>
              <span class="font-mono text-[0.6rem] tracking-widest uppercase text-text-dim">
                {item.techWave}
              </span>
            </div>
            <p class="text-text-muted text-sm">{item.role}</p>
            <p class="font-mono text-xs text-text-dim mt-1">{item.stats}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
