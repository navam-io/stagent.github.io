---
import SectionLabel from '../ui/SectionLabel.astro';
import LayerStack from '../svg/LayerStack.astro';
import { layers } from '../../data/layers';
---
<section class="py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div data-animate>
      <SectionLabel text="The Problem" />
      <h2 class="mt-4 mb-16 max-w-2xl">
        The agent landscape in 2026 is fragmented across four layers.
      </h2>
    </div>

    <div class="grid lg:grid-cols-[1fr_280px] gap-16 items-start">
      <!-- Layer descriptions -->
      <div data-animate-stagger class="space-y-0">
        {layers.map((layer, i) => (
          <div
            data-animate
            class:list={[
              'py-6 border-b border-border',
              i === layers.length - 1 && 'border-b-0',
            ]}
          >
            <div class="flex items-baseline gap-4 mb-2">
              <span class="font-mono text-[0.6875rem] text-amber tracking-widest uppercase">
                {layer.name}
              </span>
              <span class="text-text-dim text-xs">/</span>
              <span class="text-text-muted text-sm">{layer.title}</span>
            </div>
            <p class="text-text-muted text-sm leading-relaxed mb-1">
              {layer.whatExists}
            </p>
            <p class="text-text text-sm leading-relaxed">
              <span class="text-amber font-mono text-xs">MISSING</span>{' '}
              {layer.whatsMissing}
            </p>
          </div>
        ))}
      </div>

      <!-- SVG diagram -->
      <div data-animate class="hidden lg:block sticky top-32" style="transition-delay: 200ms">
        <LayerStack class="w-full text-text" />
      </div>
    </div>
  </div>
</section>
