---
import WaitlistForm from './ui/WaitlistForm.astro';
---
<footer class="border-t border-border py-12 px-6">
  <div class="max-w-6xl mx-auto grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_auto] lg:items-end">
    <div class="max-w-2xl">
      <p class="font-mono text-xs tracking-[0.28em] uppercase text-primary mb-4">
        Subscribe Stagent Newsletter
      </p>
      <p class="text-text text-lg leading-relaxed max-w-xl">
        Get release announcements, product notes, and practical field updates on governed AI agent operations.
      </p>
      <div class="mt-6 max-w-xl">
        <WaitlistForm variant="footer" id="footer-newsletter" />
      </div>
    </div>

    <div class="flex flex-col gap-5 text-text-muted text-xs font-mono">
      <div class="flex flex-wrap items-center gap-6">
        <a href="/docs" class="hover:text-primary transition-colors">Docs</a>
        <a href="/research" class="hover:text-primary transition-colors">Research</a>
        <a href="/projects" class="hover:text-primary transition-colors">Projects</a>
        <a href="/terms" class="hover:text-primary transition-colors">Terms</a>
        <a href="/privacy" class="hover:text-primary transition-colors">Privacy</a>
        <a
          href="https://github.com/navam-io/stagent"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-primary transition-colors"
        >
          GitHub
        </a>
      </div>
      <span>&copy; 2026 Navam. Apache 2.0.</span>
    </div>
  </div>
</footer>
