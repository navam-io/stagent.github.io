---
const docsPages = [
  { href: '/docs/dashboard', label: 'Dashboard' },
  { href: '/docs/tasks', label: 'Task Execution' },
  { href: '/docs/projects', label: 'Projects' },
  { href: '/docs/agents', label: 'Agent Integration' },
  { href: '/docs/profiles', label: 'Profiles' },
  { href: '/docs/inbox', label: 'Human-in-the-Loop' },
  { href: '/docs/monitoring', label: 'Monitoring' },
  { href: '/docs/workflows', label: 'Workflows' },
  { href: '/docs/documents', label: 'Documents' },
  { href: '/docs/schedules', label: 'Schedules' },
  { href: '/docs/settings', label: 'Settings' },
];
---
<nav id="main-nav" aria-label="Main navigation" class="fixed top-0 left-0 right-0 z-40 transition-[background-color,backdrop-filter,border-color] duration-300">
  <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="font-mono text-sm tracking-[0.35em] text-text hover:text-primary transition-colors">
      S T A G E N T
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      <a
        href="/#features"
        class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
      >
        Product
      </a>
      <a
        href="/research"
        class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
      >
        Research
      </a>
      <a
        href="/projects"
        class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
      >
        Projects
      </a>
      <div class="relative group">
        <a
          href="/docs"
          class="font-mono text-xs tracking-widest text-text-muted hover:text-primary transition-colors"
        >
          Docs
        </a>
        <!-- Dropdown -->
        <div class="absolute top-full right-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-[opacity,visibility] duration-200">
          <div class="bg-surface-raised border border-border rounded-lg shadow-xl py-2 min-w-[200px]">
            {docsPages.map(({ href, label }) => (
              <a
                href={href}
                class="block px-4 py-2 text-sm text-text-muted hover:text-primary hover:bg-surface-overlay transition-colors"
              >
                {label}
              </a>
            ))}
          </div>
        </div>
      </div>
      <a
        href="https://github.com/stagent"
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-muted hover:text-primary transition-colors"
        aria-label="GitHub"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-text-muted hover:text-primary transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="hamburger-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="hidden">
        <path d="M18 6L6 18M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface/95 backdrop-blur-md">
    <div class="px-6 py-4 flex flex-col gap-3">
      <a href="/#features" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">Product</a>
      <a href="/research" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">Research</a>
      <a href="/projects" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">Projects</a>
      <a href="/docs" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">Docs</a>
      <hr class="border-border" />
      {docsPages.map(({ href, label }) => (
        <a href={href} class="text-sm text-text-muted hover:text-primary transition-colors py-1 pl-4">{label}</a>
      ))}
      <hr class="border-border" />
      <a href="https://github.com/stagent" target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-text-muted hover:text-primary transition-colors py-2">GitHub</a>
    </div>
  </div>
</nav>

<script>
  function initNav() {
    const nav = document.getElementById('main-nav');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    if (!nav || !menuBtn || !mobileMenu || !hamburgerIcon || !closeIcon) return;

    // Scroll-triggered blur
    let scrolled = false;
    function onScroll() {
      const isScrolled = window.scrollY > 40;
      if (isScrolled !== scrolled) {
        scrolled = isScrolled;
        if (scrolled) {
          nav.classList.add('bg-surface/80', 'backdrop-blur-md', 'border-b', 'border-border');
          nav.classList.remove('bg-transparent');
        } else {
          nav.classList.remove('bg-surface/80', 'backdrop-blur-md', 'border-b', 'border-border');
          nav.classList.add('bg-transparent');
        }
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Mobile menu toggle
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      hamburgerIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    // Close mobile menu on link click
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
