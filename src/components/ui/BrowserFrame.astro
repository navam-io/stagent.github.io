---
interface Props {
  src: string;
  alt: string;
  class?: string;
  perspective?: boolean;
}

const { src, alt, class: className = '', perspective = false } = Astro.props;
---
<div class:list={[
  "rounded-xl overflow-hidden border border-border shadow-2xl shadow-primary/5",
  perspective && "transform perspective-[1200px] rotateX(2deg) rotateY(-1deg)",
  className
]}>
  <!-- macOS title bar -->
  <div class="bg-surface-raised border-b border-border px-4 py-3 flex items-center gap-2">
    <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
    <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
    <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
  </div>
  <!-- Screenshot -->
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="w-full block"
  />
</div>
