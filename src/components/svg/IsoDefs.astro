---
// Shared SVG <defs> for all isometric visualizations
// Include inside each SVG's <svg> element
---
<defs>
  <!-- Ambient glow for core/amber elements -->
  <filter id="amber-glow" x="-50%" y="-50%" width="200%" height="200%">
    <feDropShadow dx="0" dy="0" stdDeviation="6" flood-color="var(--color-amber)" flood-opacity="0.4" />
  </filter>

  <!-- Subtle grid pattern for platform top faces -->
  <pattern id="iso-grid" width="10" height="10" patternUnits="userSpaceOnUse">
    <path d="M10 0 L0 0 0 10" fill="none" stroke="currentColor" stroke-width="0.3" opacity="0.08" />
  </pattern>

  <!-- Depth gradient for left side faces (darker) -->
  <linearGradient id="side-fade" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="currentColor" stop-opacity="0.12" />
    <stop offset="100%" stop-color="currentColor" stop-opacity="0.04" />
  </linearGradient>

  <!-- Depth gradient for right side faces -->
  <linearGradient id="side-fade-right" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="currentColor" stop-opacity="0.08" />
    <stop offset="100%" stop-color="currentColor" stop-opacity="0.02" />
  </linearGradient>

  <!-- Amber gradient for left side faces of highlighted platforms -->
  <linearGradient id="amber-side-fade" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="var(--color-amber)" stop-opacity="0.25" />
    <stop offset="100%" stop-color="var(--color-amber)" stop-opacity="0.08" />
  </linearGradient>

  <!-- Amber gradient for right side faces of highlighted platforms -->
  <linearGradient id="amber-side-right" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="var(--color-amber)" stop-opacity="0.18" />
    <stop offset="100%" stop-color="var(--color-amber)" stop-opacity="0.05" />
  </linearGradient>

  <!-- Teal gradient for left side faces -->
  <linearGradient id="teal-side-fade" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="var(--color-teal)" stop-opacity="0.25" />
    <stop offset="100%" stop-color="var(--color-teal)" stop-opacity="0.08" />
  </linearGradient>

  <!-- Teal gradient for right side faces -->
  <linearGradient id="teal-side-right" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="var(--color-teal)" stop-opacity="0.18" />
    <stop offset="100%" stop-color="var(--color-teal)" stop-opacity="0.05" />
  </linearGradient>

  <!-- Teal glow filter -->
  <filter id="teal-glow" x="-50%" y="-50%" width="200%" height="200%">
    <feDropShadow dx="0" dy="0" stdDeviation="6" flood-color="var(--color-teal)" flood-opacity="0.4" />
  </filter>
</defs>
