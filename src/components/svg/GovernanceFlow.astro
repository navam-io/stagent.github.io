---
/**
 * canUseTool 5-step governance flow diagram
 * Shows the human-in-the-loop permission cycle
 */
---
<svg viewBox="0 0 800 180" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-2xl mx-auto" data-svg-animate>
  <!-- Steps -->
  <g class="svg-reveal">
    <!-- Step 1: Agent requests -->
    <rect x="10" y="30" width="130" height="85" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <text x="75" y="62" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="14" text-anchor="middle" font-weight="600">1. AGENT</text>
    <text x="75" y="82" fill="oklch(0.6 0.02 250)" font-family="var(--font-body)" font-size="14" text-anchor="middle">Requests tool</text>

    <!-- Step 2: canUseTool check -->
    <rect x="175" y="30" width="130" height="85" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" />
    <text x="240" y="62" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="14" text-anchor="middle" font-weight="600">2. canUseTool</text>
    <text x="240" y="82" fill="oklch(0.6 0.02 250)" font-family="var(--font-body)" font-size="14" text-anchor="middle">Polls approval</text>

    <!-- Step 3: Notification created -->
    <rect x="340" y="30" width="130" height="85" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <text x="405" y="62" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="14" text-anchor="middle" font-weight="600">3. NOTIFY</text>
    <text x="405" y="82" fill="oklch(0.6 0.02 250)" font-family="var(--font-body)" font-size="14" text-anchor="middle">Inbox alert</text>

    <!-- Step 4: Human reviews -->
    <rect x="505" y="30" width="130" height="85" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.65 0.15 170)" stroke-width="1.5" />
    <text x="570" y="62" fill="oklch(0.65 0.15 170)" font-family="var(--font-mono)" font-size="14" text-anchor="middle" font-weight="600">4. HUMAN</text>
    <text x="570" y="82" fill="oklch(0.6 0.02 250)" font-family="var(--font-body)" font-size="14" text-anchor="middle">Reviews & decides</text>

    <!-- Step 5: Agent executes -->
    <rect x="670" y="30" width="120" height="85" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <text x="730" y="62" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="14" text-anchor="middle" font-weight="600">5. EXECUTE</text>
    <text x="730" y="82" fill="oklch(0.6 0.02 250)" font-family="var(--font-body)" font-size="14" text-anchor="middle">Tool runs</text>
  </g>

  <!-- Arrows -->
  <g class="svg-reveal svg-reveal-d2">
    <line x1="140" y1="72" x2="175" y2="72" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" marker-end="url(#arrowhead)" />
    <line x1="305" y1="72" x2="340" y2="72" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" marker-end="url(#arrowhead)" />
    <line x1="470" y1="72" x2="505" y2="72" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" marker-end="url(#arrowhead)" />
    <line x1="635" y1="72" x2="670" y2="72" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" marker-end="url(#arrowhead)" />
  </g>

  <defs>
    <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
      <polygon points="0 0, 8 3, 0 6" fill="oklch(0.65 0.18 250)" />
    </marker>
  </defs>

  <!-- Labels below -->
  <g class="svg-reveal svg-reveal-d3">
    <text x="400" y="150" fill="oklch(0.5 0.02 250)" font-family="var(--font-mono)" font-size="14" text-anchor="middle">
      Notification table as message queue — agent polls until human responds
    </text>
  </g>
</svg>
