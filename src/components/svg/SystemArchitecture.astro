---
/**
 * 4-layer architecture stack: Human → Coordination → Agent → Data
 * Blue-indigo OKLCH palette, scroll-reveal animations
 */
---
<svg viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-lg mx-auto" data-svg-animate>
  <defs>
    <linearGradient id="arch-gradient" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="oklch(0.65 0.18 250)" stop-opacity="0.3" />
      <stop offset="100%" stop-color="oklch(0.65 0.18 250)" stop-opacity="0.05" />
    </linearGradient>
  </defs>

  <!-- Layer backgrounds -->
  <g class="svg-reveal">
    <!-- Human Layer -->
    <rect x="60" y="20" width="700" height="90" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <text x="120" y="58" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="17" font-weight="600">HUMAN LAYER</text>
    <text x="120" y="84" fill="oklch(0.6 0.02 250)" font-family="var(--font-body)" font-size="15">Home · Dashboard · Inbox · Profiles · Schedules</text>

    <!-- Coordination Layer -->
    <rect x="60" y="135" width="700" height="90" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <text x="120" y="173" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="17" font-weight="600">COORDINATION LAYER</text>
    <text x="120" y="199" fill="oklch(0.6 0.02 250)" font-family="var(--font-body)" font-size="15">Workflow Blueprints · Task Queue · Schedules · Notifications</text>

    <!-- Agent Layer -->
    <rect x="60" y="250" width="700" height="90" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <text x="120" y="288" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="17" font-weight="600">AGENT LAYER</text>
    <text x="120" y="314" fill="oklch(0.6 0.02 250)" font-family="var(--font-body)" font-size="15">Claude Agent SDK · canUseTool Polling · Execution Manager · SSE Logs</text>

    <!-- Data Layer -->
    <rect x="60" y="365" width="700" height="90" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <text x="120" y="403" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="17" font-weight="600">DATA LAYER</text>
    <text x="120" y="429" fill="oklch(0.6 0.02 250)" font-family="var(--font-body)" font-size="15">SQLite · Drizzle ORM · Local Files · Audit Trail · ~/.stagent/</text>
  </g>

  <!-- Connection arrows -->
  <g class="svg-reveal svg-reveal-d2">
    <line x1="410" y1="110" x2="410" y2="135" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" stroke-dasharray="4 3" />
    <line x1="410" y1="225" x2="410" y2="250" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" stroke-dasharray="4 3" />
    <line x1="410" y1="340" x2="410" y2="365" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" stroke-dasharray="4 3" />
  </g>

  <!-- Arrow heads -->
  <g class="dot-pop">
    <circle cx="410" cy="122" r="3" fill="oklch(0.65 0.18 250)" />
    <circle cx="410" cy="237" r="3" fill="oklch(0.65 0.18 250)" />
    <circle cx="410" cy="352" r="3" fill="oklch(0.65 0.18 250)" />
  </g>

  <!-- Layer numbers -->
  <g class="svg-reveal svg-reveal-d3">
    <circle cx="82" cy="65" r="16" fill="oklch(0.65 0.18 250)" fill-opacity="0.15" />
    <text x="82" y="71" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="15" text-anchor="middle" font-weight="700">1</text>
    <circle cx="82" cy="180" r="16" fill="oklch(0.65 0.18 250)" fill-opacity="0.15" />
    <text x="82" y="186" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="15" text-anchor="middle" font-weight="700">2</text>
    <circle cx="82" cy="295" r="16" fill="oklch(0.65 0.18 250)" fill-opacity="0.15" />
    <text x="82" y="301" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="15" text-anchor="middle" font-weight="700">3</text>
    <circle cx="82" cy="410" r="16" fill="oklch(0.65 0.18 250)" fill-opacity="0.15" />
    <text x="82" y="416" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="15" text-anchor="middle" font-weight="700">4</text>
  </g>
</svg>
