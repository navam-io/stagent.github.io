---
/**
 * Feature velocity bar chart — features shipped per development day
 * Data: Day 1-3 → 0, 18, 3 (21 features across 3 days)
 */
const days = [
  { label: 'D1', value: 0 },
  { label: 'D2', value: 18 },
  { label: 'D3', value: 3 },
];

const maxValue = 20;
const barWidth = 80;
const gap = 40;
const chartHeight = 180;
const chartTop = 20;
const chartLeft = 40;
const totalWidth = chartLeft + days.length * (barWidth + gap) + 20;
---
<svg viewBox={`0 0 ${totalWidth} 260`} xmlns="http://www.w3.org/2000/svg" class="w-full max-w-md mx-auto" data-svg-animate>
  <!-- Y-axis labels -->
  <g class="svg-reveal">
    {[0, 5, 10, 15, 20].map((v) => {
      const y = chartTop + chartHeight - (v / maxValue) * chartHeight;
      return (
        <>
          <text x="25" y={y + 4} fill="oklch(0.5 0.02 250)" font-family="var(--font-mono)" font-size="15" text-anchor="end">{v}</text>
          <line x1="35" y1={y} x2={totalWidth - 10} y2={y} stroke="oklch(0.25 0.02 250)" stroke-width="0.5" stroke-dasharray="4 4" />
        </>
      );
    })}
  </g>

  <!-- Bars -->
  {days.map(({ label, value }, i) => {
    const x = chartLeft + i * (barWidth + gap);
    const barHeight = (value / maxValue) * chartHeight;
    const y = chartTop + chartHeight - barHeight;
    return (
      <g class={`bar-grow svg-reveal-d${i + 1}`} style={`transform-origin: ${x + barWidth / 2}px ${chartTop + chartHeight}px`}>
        {value > 0 && (
          <rect
            x={x}
            y={y}
            width={barWidth}
            height={barHeight}
            rx="4"
            fill="oklch(0.65 0.18 250)"
            fill-opacity="0.8"
          />
        )}
        <text
          x={x + barWidth / 2}
          y={value > 0 ? y - 8 : chartTop + chartHeight - 8}
          fill="oklch(0.65 0.18 250)"
          font-family="var(--font-mono)"
          font-size="18"
          font-weight="700"
          text-anchor="middle"
        >
          {value}
        </text>
        <text
          x={x + barWidth / 2}
          y={chartTop + chartHeight + 20}
          fill="oklch(0.5 0.02 250)"
          font-family="var(--font-mono)"
          font-size="15"
          text-anchor="middle"
        >
          {label}
        </text>
      </g>
    );
  })}
</svg>
