---
import IsoDefs from './IsoDefs.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// Center of the quadrant — shifted right to give room for left label
const CX = 280;
const CY = 190;
const AXIS_LEN = 170;

// Competitor dots positioned in the 4 quadrants
const competitors = [
  { name: 'Gateway Control', x: CX - 90, y: CY + 60, r: 5 },
  { name: 'Workspace Orch.', x: CX + 60, y: CY + 70, r: 5 },
  { name: 'Cloud Multi-Model', x: CX - 80, y: CY - 50, r: 5 },
  { name: 'Desktop Agents', x: CX + 70, y: CY - 40, r: 5 },
];

// STAGENT in the top-right (Desktop + Autonomous) quadrant
const stagent = { name: 'STAGENT', x: CX + 100, y: CY - 90, r: 8 };
---
<svg
  viewBox="0 0 560 380"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  data-svg-animate
>
  <IsoDefs />

  <style>
    .quad-dot { transition: transform 0.2s ease, opacity 0.2s ease; transform-origin: center; }
    .quad-dot:hover { opacity: 1 !important; }
    .quad-dot:hover circle { r: 7; }
    .quad-dot:hover text { opacity: 1; }
  </style>

  <!-- Subtle quadrant background fills -->
  <rect x={CX - AXIS_LEN} y={CY - AXIS_LEN} width={AXIS_LEN} height={AXIS_LEN} fill="currentColor" opacity="0.02" />
  <rect x={CX} y={CY - AXIS_LEN} width={AXIS_LEN} height={AXIS_LEN} fill="var(--color-amber)" opacity="0.03" />
  <rect x={CX - AXIS_LEN} y={CY} width={AXIS_LEN} height={AXIS_LEN} fill="currentColor" opacity="0.015" />
  <rect x={CX} y={CY} width={AXIS_LEN} height={AXIS_LEN} fill="currentColor" opacity="0.02" />

  <!-- Horizontal axis: REACTIVE ↔ AUTONOMOUS -->
  <g class="svg-reveal svg-reveal-d1">
    <line
      x1={CX - AXIS_LEN}
      y1={CY}
      x2={CX + AXIS_LEN}
      y2={CY}
      stroke="currentColor"
      stroke-width="1"
      opacity="0.2"
    />
    <!-- Arrow heads -->
    <polygon
      points={`${CX - AXIS_LEN - 4},${CY} ${CX - AXIS_LEN + 3},${CY - 3} ${CX - AXIS_LEN + 3},${CY + 3}`}
      fill="currentColor"
      opacity="0.2"
    />
    <polygon
      points={`${CX + AXIS_LEN + 4},${CY} ${CX + AXIS_LEN - 3},${CY - 3} ${CX + AXIS_LEN - 3},${CY + 3}`}
      fill="currentColor"
      opacity="0.2"
    />
    <text
      x={CX - AXIS_LEN - 8}
      y={CY + 4}
      text-anchor="end"
      fill="var(--color-teal)"
      font-family="var(--font-mono)"
      font-size="11"
      letter-spacing="0.08em"
      opacity="0.6"
    >REACTIVE</text>
    <text
      x={CX + AXIS_LEN + 8}
      y={CY + 4}
      text-anchor="start"
      fill="var(--color-teal)"
      font-family="var(--font-mono)"
      font-size="11"
      letter-spacing="0.08em"
      opacity="0.6"
    >AUTONOMOUS</text>
  </g>

  <!-- Vertical axis: DESKTOP ↔ CLOUD -->
  <g class="svg-reveal svg-reveal-d1">
    <line
      x1={CX}
      y1={CY - AXIS_LEN}
      x2={CX}
      y2={CY + AXIS_LEN}
      stroke="currentColor"
      stroke-width="1"
      opacity="0.2"
    />
    <polygon
      points={`${CX},${CY - AXIS_LEN - 4} ${CX - 3},${CY - AXIS_LEN + 3} ${CX + 3},${CY - AXIS_LEN + 3}`}
      fill="currentColor"
      opacity="0.2"
    />
    <polygon
      points={`${CX},${CY + AXIS_LEN + 4} ${CX - 3},${CY + AXIS_LEN - 3} ${CX + 3},${CY + AXIS_LEN - 3}`}
      fill="currentColor"
      opacity="0.2"
    />
    <text
      x={CX}
      y={CY - AXIS_LEN - 10}
      text-anchor="middle"
      fill="var(--color-teal)"
      font-family="var(--font-mono)"
      font-size="11"
      letter-spacing="0.08em"
      opacity="0.6"
    >DESKTOP</text>
    <text
      x={CX}
      y={CY + AXIS_LEN + 20}
      text-anchor="middle"
      fill="var(--color-teal)"
      font-family="var(--font-mono)"
      font-size="11"
      letter-spacing="0.08em"
      opacity="0.6"
    >CLOUD</text>
  </g>

  <!-- Competitor dots -->
  {competitors.map((c, i) => (
    <g class={`quad-dot dot-pop svg-reveal-d${i + 2}`} style="opacity: 0.6">
      <circle
        cx={c.x}
        cy={c.y}
        r={c.r}
        fill="none"
        stroke="currentColor"
        stroke-width="1"
      />
      <text
        x={c.x}
        y={c.y - 10}
        text-anchor="middle"
        fill="currentColor"
        font-family="var(--font-mono)"
        font-size="10"
        opacity="0.6"
      >{c.name}</text>
    </g>
  ))}

  <!-- STAGENT dot — amber, prominent -->
  <g class="dot-pop svg-reveal-d6">
    <!-- Glow ring -->
    <circle
      cx={stagent.x}
      cy={stagent.y}
      r={stagent.r + 8}
      fill="none"
      stroke="var(--color-amber)"
      stroke-width="0.5"
      opacity="0.2"
    />
    <!-- Main dot -->
    <circle
      cx={stagent.x}
      cy={stagent.y}
      r={stagent.r}
      fill="var(--color-amber-dim)"
      stroke="var(--color-amber)"
      stroke-width="1.5"
    />
    <!-- Amber glow -->
    <circle
      cx={stagent.x}
      cy={stagent.y}
      r={stagent.r + 4}
      fill="none"
      filter="url(#amber-glow)"
      stroke="var(--color-amber)"
      stroke-width="0.5"
      opacity="0.3"
    />
    <!-- Label -->
    <text
      x={stagent.x}
      y={stagent.y - 16}
      text-anchor="middle"
      fill="var(--color-amber)"
      font-family="var(--font-mono)"
      font-size="12"
      font-weight="bold"
      letter-spacing="0.15em"
    >STAGENT</text>
  </g>
</svg>
