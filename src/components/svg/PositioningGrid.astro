---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const competitors = [
  { name: 'Perplexity', x: 60, y: 60 },
  { name: 'OpenClaw', x: 180, y: 240 },
  { name: 'Conductor', x: 280, y: 180 },
  { name: 'Cowork', x: 260, y: 160 },
];
---
<svg
  viewBox="0 0 360 300"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <!-- Axes -->
  <line x1="30" y1="150" x2="330" y2="150" stroke="currentColor" stroke-width="0.5" opacity="0.2" />
  <line x1="180" y1="20" x2="180" y2="280" stroke="currentColor" stroke-width="0.5" opacity="0.2" />

  <!-- Axis labels -->
  <text x="45" y="145" fill="currentColor" font-family="var(--font-mono)" font-size="7" letter-spacing="0.1em" opacity="0.3">CLOUD</text>
  <text x="290" y="145" fill="currentColor" font-family="var(--font-mono)" font-size="7" letter-spacing="0.1em" opacity="0.3">DESKTOP</text>
  <text x="185" y="30" fill="currentColor" font-family="var(--font-mono)" font-size="7" letter-spacing="0.1em" opacity="0.3">AUTONOMOUS</text>
  <text x="185" y="275" fill="currentColor" font-family="var(--font-mono)" font-size="7" letter-spacing="0.1em" opacity="0.3">REACTIVE</text>

  <!-- Quadrant fill -->
  <rect x="180" y="20" width="150" height="130" fill="var(--color-amber-dim)" opacity="0.15" rx="4" />

  <!-- Competitor dots -->
  {competitors.map((c) => (
    <g>
      <circle cx={c.x} cy={c.y} r="5" fill="currentColor" opacity="0.25" />
      <text
        x={c.x}
        y={c.y - 10}
        text-anchor="middle"
        fill="currentColor"
        font-family="var(--font-mono)"
        font-size="7"
        opacity="0.35"
      >
        {c.name}
      </text>
    </g>
  ))}

  <!-- Stagent (amber highlighted) -->
  <circle cx="230" cy="90" r="8" fill="var(--color-amber-dim)" stroke="var(--color-amber)" stroke-width="1.5" />
  <circle cx="230" cy="90" r="14" stroke="var(--color-amber)" stroke-width="0.5" opacity="0.3" />
  <text
    x="230"
    y="75"
    text-anchor="middle"
    fill="var(--color-amber)"
    font-family="var(--font-mono)"
    font-size="9"
    font-weight="bold"
    letter-spacing="0.15em"
  >
    STAGENT
  </text>
</svg>
