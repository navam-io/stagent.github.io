---
import { isoPlatform, isoProject, isoGridLines, isoLine } from '../../utils/isometric';
import IsoDefs from './IsoDefs.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const layers = [
  { label: 'HARNESS', z: 90, isCore: true, opacity: 1 },
  { label: 'ORCHESTRATION', z: 60, isCore: false, opacity: 0.7, isTeal: true },
  { label: 'APPLICATION', z: 30, isCore: false, opacity: 0.6 },
  { label: 'INFRASTRUCTURE', z: 0, isCore: false, opacity: 0.5 },
];

const W = 120;  // platform width
const D = 60;   // platform depth
const H = 8;    // platform height/thickness

// Compute all platform faces, centers, and right-side label positions
const platforms = layers.map((layer) => {
  const faces = isoPlatform(0, 0, layer.z, W, D, H);
  const center = isoProject(W / 2, D / 2, layer.z + H);
  // Right edge of top face — used for label leader line origin
  const rightEdge = isoProject(W, D / 4, layer.z + H);
  return { ...layer, faces, center, rightEdge };
});

// Grid lines for HARNESS (top layer) surface
const gridPaths = isoGridLines(0, 0, layers[0].z + H, W, D, 6);

// Vertical dashed connectors between layers
const connectors = [];
for (let i = 0; i < layers.length - 1; i++) {
  const fromZ = layers[i].z;
  const toZ = layers[i + 1].z + H;
  connectors.push(isoLine(W / 2, D / 2, fromZ, W / 2, D / 2, toZ));
}

// Label column X position (right of all platforms)
const LABEL_X = 160;
---
<svg
  viewBox="0 0 420 220"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  data-svg-animate
>
  <IsoDefs />

  <g transform="translate(135, 105)">
    <!-- Dashed vertical connectors between layers -->
    {connectors.map((d, i) => (
      <path
        d={d}
        stroke="currentColor"
        stroke-width="0.75"
        stroke-dasharray="4 3"
        opacity="0.2"
        class="iso-dash"
      />
    ))}

    <!-- Platforms from bottom to top -->
    {platforms.slice().reverse().map((p, i) => (
      <g opacity={p.opacity} class={`svg-hover-lift svg-reveal svg-reveal-d${4 - i}`}>
        <!-- Left face (darker) -->
        <polygon
          points={p.faces.left}
          fill={p.isCore ? 'url(#amber-side-fade)' : p.isTeal ? 'url(#teal-side-fade)' : 'url(#side-fade)'}
          stroke={p.isCore ? 'var(--color-amber)' : p.isTeal ? 'var(--color-teal)' : 'currentColor'}
          stroke-width={p.isCore || p.isTeal ? 1 : 0.5}
          stroke-opacity={p.isCore || p.isTeal ? 0.6 : 0.3}
        />
        <!-- Right face (slightly lighter) -->
        <polygon
          points={p.faces.right}
          fill={p.isCore ? 'url(#amber-side-right)' : p.isTeal ? 'url(#teal-side-right)' : 'url(#side-fade-right)'}
          stroke={p.isCore ? 'var(--color-amber)' : p.isTeal ? 'var(--color-teal)' : 'currentColor'}
          stroke-width={p.isCore || p.isTeal ? 1 : 0.5}
          stroke-opacity={p.isCore || p.isTeal ? 0.6 : 0.3}
        />
        <!-- Top face -->
        <polygon
          points={p.faces.top}
          fill={p.isCore ? 'var(--color-amber-dim)' : p.isTeal ? 'var(--color-teal-dim)' : 'none'}
          stroke={p.isCore ? 'var(--color-amber)' : p.isTeal ? 'var(--color-teal)' : 'currentColor'}
          stroke-width={p.isCore ? 1.5 : p.isTeal ? 1.2 : 0.75}
          class={p.isCore ? 'iso-breathe' : ''}
        />

        <!-- Grid lines on HARNESS top face -->
        {p.isCore && gridPaths.map((gd) => (
          <path
            d={gd}
            stroke="var(--color-amber)"
            stroke-width="0.3"
            opacity="0.15"
          />
        ))}

        <!-- Leader line from platform right edge to label -->
        <line
          x1={p.rightEdge.x}
          y1={p.rightEdge.y}
          x2={LABEL_X - 5}
          y2={p.rightEdge.y}
          stroke={p.isCore ? 'var(--color-amber)' : p.isTeal ? 'var(--color-teal)' : 'currentColor'}
          stroke-width="0.75"
          stroke-dasharray="3 3"
          opacity="0.3"
        />

        <!-- Label to the right -->
        <text
          x={LABEL_X}
          y={p.rightEdge.y + 4}
          fill={p.isCore ? 'var(--color-amber)' : p.isTeal ? 'var(--color-teal)' : 'currentColor'}
          font-family="var(--font-mono)"
          font-size="12"
          letter-spacing="0.12em"
        >
          {p.label}
        </text>
      </g>
    ))}

    <!-- Amber glow overlay on HARNESS -->
    <polygon
      points={platforms[0].faces.top}
      fill="none"
      filter="url(#amber-glow)"
      stroke="var(--color-amber)"
      stroke-width="0.5"
      opacity="0.3"
      class="iso-glow"
    />
  </g>
</svg>
