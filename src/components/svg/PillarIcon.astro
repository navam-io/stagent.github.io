---
interface Props {
  icon: 'persistence' | 'orchestration' | 'memory' | 'autonomy' | 'hybrid';
  class?: string;
}

const { icon, class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 48 48"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  {icon === 'persistence' && (
    /* Hourglass / timeline */
    <g stroke="var(--color-amber)" stroke-width="1.5">
      <line x1="14" y1="8" x2="34" y2="8" />
      <line x1="14" y1="40" x2="34" y2="40" />
      <path d="M14 8 L24 24 L14 40" fill="none" />
      <path d="M34 8 L24 24 L34 40" fill="none" />
      <circle cx="24" cy="24" r="2" fill="var(--color-amber)" />
    </g>
  )}
  {icon === 'orchestration' && (
    /* Multi-node network */
    <g stroke="var(--color-amber)" stroke-width="1.5">
      <circle cx="24" cy="12" r="4" />
      <circle cx="12" cy="32" r="4" />
      <circle cx="36" cy="32" r="4" />
      <circle cx="24" cy="38" r="3" />
      <line x1="24" y1="16" x2="12" y2="28" />
      <line x1="24" y1="16" x2="36" y2="28" />
      <line x1="12" y1="36" x2="24" y2="38" />
      <line x1="36" y1="36" x2="24" y2="38" />
    </g>
  )}
  {icon === 'memory' && (
    /* Layered circles (memory tiers) */
    <g stroke="var(--color-amber)" stroke-width="1.5">
      <ellipse cx="24" cy="14" rx="14" ry="6" />
      <ellipse cx="24" cy="24" rx="14" ry="6" />
      <ellipse cx="24" cy="34" rx="14" ry="6" />
      <line x1="10" y1="14" x2="10" y2="34" />
      <line x1="38" y1="14" x2="38" y2="34" />
    </g>
  )}
  {icon === 'autonomy' && (
    /* Shield with gradient levels */
    <g stroke="var(--color-amber)" stroke-width="1.5">
      <path d="M24 6 L38 14 L38 30 Q38 40 24 44 Q10 40 10 30 L10 14 Z" fill="none" />
      <line x1="14" y1="22" x2="34" y2="22" opacity="0.4" />
      <line x1="14" y1="30" x2="34" y2="30" opacity="0.4" />
      <circle cx="24" cy="16" r="2" fill="var(--color-amber)" />
    </g>
  )}
  {icon === 'hybrid' && (
    /* Desktop + cloud bridge */
    <g stroke="var(--color-amber)" stroke-width="1.5">
      <rect x="6" y="22" width="16" height="12" rx="2" />
      <line x1="10" y1="34" x2="18" y2="34" />
      <line x1="14" y1="34" x2="14" y2="38" />
      <path d="M30 18 Q28 12 32 10 Q36 8 38 12 Q42 10 42 16 Q44 18 42 20 L30 20 Z" fill="none" />
      <line x1="22" y1="28" x2="30" y2="19" stroke-dasharray="3 2" opacity="0.6" />
    </g>
  )}
</svg>
