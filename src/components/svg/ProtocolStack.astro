---
import type { Protocol } from '../../data/protocols';
import IsoDefs from './IsoDefs.astro';

interface Props {
  protocols: Protocol[];
  class?: string;
}

const { protocols, class: className = '' } = Astro.props;

// Layout constants
const SPINE_X = 250;
const BOX_W = 180;
const BOX_H = 52;
const GAP = 12;
const START_Y = 30;
const CONNECTOR_LEN = 30;

// Position boxes alternating left/right — core on left, non-core on right
const boxes = protocols.map((proto, i) => {
  const y = START_Y + i * (BOX_H + GAP);
  const isLeft = proto.isCore;
  const boxX = isLeft ? SPINE_X - CONNECTOR_LEN - BOX_W : SPINE_X + CONNECTOR_LEN;
  return { ...proto, y, boxX, isLeft, index: i };
});

const spineHeight = boxes.length * (BOX_H + GAP) - GAP;
---
<svg
  viewBox="0 0 500 420"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  data-svg-animate
>
  <IsoDefs />

  <!-- Central vertical spine -->
  <line
    x1={SPINE_X}
    y1={START_Y}
    x2={SPINE_X}
    y2={START_Y + spineHeight}
    stroke="currentColor"
    stroke-width="1"
    opacity="0.2"
    class="line-draw"
    style={`--path-length: ${spineHeight}`}
  />

  <!-- Small dots along spine at each connection point -->
  {boxes.map((b) => (
    <circle
      cx={SPINE_X}
      cy={b.y + BOX_H / 2}
      r="3"
      fill={b.isCore ? 'var(--color-amber)' : 'var(--color-teal)'}
      opacity="0.6"
      class={`dot-pop svg-reveal-d${b.index + 1}`}
    />
  ))}

  <!-- Protocol boxes -->
  {boxes.map((b) => (
    <g class={`svg-reveal svg-reveal-d${b.index + 1} svg-hover-lift`}>
      <!-- Horizontal connector from spine to box -->
      <line
        x1={SPINE_X}
        y1={b.y + BOX_H / 2}
        x2={b.isLeft ? b.boxX + BOX_W : b.boxX}
        y2={b.y + BOX_H / 2}
        stroke={b.isCore ? 'var(--color-amber)' : 'var(--color-teal)'}
        stroke-width="0.75"
        stroke-dasharray="4 3"
        opacity="0.3"
      />

      <!-- Box -->
      <rect
        x={b.boxX}
        y={b.y}
        width={BOX_W}
        height={BOX_H}
        rx="4"
        fill={b.isCore ? 'var(--color-amber-dim)' : 'var(--color-teal-dim)'}
        stroke={b.isCore ? 'var(--color-amber)' : 'var(--color-teal)'}
        stroke-width={b.isCore ? 1.2 : 0.8}
        stroke-opacity="0.6"
      />

      <!-- Protocol name (bold) -->
      <text
        x={b.boxX + 14}
        y={b.y + 22}
        fill={b.isCore ? 'var(--color-amber)' : 'var(--color-teal)'}
        font-family="var(--font-mono)"
        font-size="12"
        font-weight="bold"
        letter-spacing="0.08em"
      >
        {b.label}
      </text>

      <!-- Description -->
      <text
        x={b.boxX + 14}
        y={b.y + 40}
        fill="currentColor"
        font-family="var(--font-body)"
        font-size="10"
        opacity="0.5"
      >
        {b.description}
      </text>
    </g>
  ))}
</svg>
