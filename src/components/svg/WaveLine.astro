---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 800 80"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  preserveAspectRatio="none"
>
  <path
    d="M0 40 Q100 10 200 40 Q300 70 400 40 Q500 10 600 40 Q700 70 800 40"
    stroke="currentColor"
    stroke-width="0.75"
    opacity="0.15"
    fill="none"
  />
  <path
    d="M0 50 Q100 25 200 50 Q300 75 400 50 Q500 25 600 50 Q700 75 800 50"
    stroke="currentColor"
    stroke-width="0.5"
    opacity="0.08"
    fill="none"
  />
</svg>
