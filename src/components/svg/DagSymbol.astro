---
import IsoDefs from './IsoDefs.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// 2D tree nodes — root at top, leaves at bottom
const nodes = [
  { id: 'root', x: 190, y: 40, r: 14, color: 'var(--color-amber)', fill: 'var(--color-amber-dim)', isCore: true, level: 0 },
  { id: 'L1a', x: 120, y: 120, r: 10, color: 'var(--color-teal)', fill: 'var(--color-teal-dim)', isCore: false, level: 1 },
  { id: 'L1b', x: 260, y: 120, r: 10, color: 'var(--color-teal)', fill: 'var(--color-teal-dim)', isCore: false, level: 1 },
  { id: 'L2a', x: 70, y: 200, r: 8, color: 'var(--color-teal)', fill: 'var(--color-teal-dim)', isCore: false, level: 2 },
  { id: 'L2b', x: 190, y: 200, r: 8, color: 'var(--color-teal)', fill: 'var(--color-teal-dim)', isCore: false, level: 2 },
  { id: 'L2c', x: 310, y: 200, r: 8, color: 'var(--color-teal)', fill: 'var(--color-teal-dim)', isCore: false, level: 2 },
  { id: 'L3a', x: 130, y: 270, r: 7, color: 'currentColor', fill: 'none', isCore: false, level: 3 },
  { id: 'L3b', x: 250, y: 270, r: 7, color: 'currentColor', fill: 'none', isCore: false, level: 3 },
];

// Edges as [fromIndex, toIndex] — DAG allows shared children
const edges: [number, number][] = [
  [0, 1], [0, 2],
  [1, 3], [1, 4],
  [2, 4], [2, 5],
  [3, 6], [4, 6], [4, 7], [5, 7],
];

// Compute cubic bezier path for each edge
const edgePaths = edges.map(([from, to]) => {
  const a = nodes[from];
  const b = nodes[to];
  const midY = (a.y + b.y) / 2;
  // Control points create a smooth curve
  return `M${a.x},${a.y + a.r} C${a.x},${midY} ${b.x},${midY} ${b.x},${b.y - b.r}`;
});

// Approximate path lengths for line-draw animation
const pathLengths = edges.map(([from, to]) => {
  const a = nodes[from];
  const b = nodes[to];
  return Math.hypot(b.x - a.x, b.y - a.y) * 1.3; // rough estimate with curve factor
});
---
<svg
  viewBox="0 0 380 300"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  data-svg-animate
>
  <IsoDefs />

  <style>
    .dag-node { transition: opacity 0.2s ease; }
    .dag-node:hover { opacity: 1 !important; }
    .dag-node:hover ~ .dag-edge { stroke-opacity: 0.6; }
  </style>

  <!-- Edges (behind nodes) -->
  {edgePaths.map((d, i) => (
    <path
      d={d}
      stroke="var(--color-teal)"
      stroke-width="1.2"
      fill="none"
      opacity="0.25"
      class={`line-draw svg-reveal-d${Math.min(nodes[edges[i][0]].level + 1, 6)}`}
      style={`--path-length: ${pathLengths[i]}`}
    />
  ))}

  <!-- Nodes — drawn top-down by level -->
  {nodes.map((n, i) => (
    <g class={`dag-node dot-pop svg-reveal-d${n.level + 1}`}>
      <circle
        cx={n.x}
        cy={n.y}
        r={n.r}
        fill={n.fill}
        stroke={n.color}
        stroke-width={n.isCore ? 2 : 1}
        opacity={n.isCore ? 1 : 0.6}
      />

      {/* Amber glow on root */}
      {n.isCore && (
        <circle
          cx={n.x}
          cy={n.y}
          r={n.r + 6}
          fill="none"
          filter="url(#amber-glow)"
          stroke="var(--color-amber)"
          stroke-width="0.5"
          opacity="0.25"
        />
      )}
    </g>
  ))}
</svg>
