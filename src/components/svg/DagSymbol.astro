---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 400 400"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <!-- Directed edges -->
  <line x1="200" y1="60" x2="120" y2="150" stroke="currentColor" stroke-width="1" opacity="0.3" />
  <line x1="200" y1="60" x2="280" y2="150" stroke="currentColor" stroke-width="1" opacity="0.3" />
  <line x1="120" y1="150" x2="80" y2="250" stroke="currentColor" stroke-width="1" opacity="0.3" />
  <line x1="120" y1="150" x2="200" y2="250" stroke="currentColor" stroke-width="1" opacity="0.3" />
  <line x1="280" y1="150" x2="200" y2="250" stroke="currentColor" stroke-width="1" opacity="0.3" />
  <line x1="280" y1="150" x2="320" y2="250" stroke="currentColor" stroke-width="1" opacity="0.3" />
  <line x1="80" y1="250" x2="160" y2="340" stroke="currentColor" stroke-width="1" opacity="0.3" />
  <line x1="200" y1="250" x2="160" y2="340" stroke="currentColor" stroke-width="1" opacity="0.3" />
  <line x1="200" y1="250" x2="260" y2="340" stroke="currentColor" stroke-width="1" opacity="0.3" />
  <line x1="320" y1="250" x2="260" y2="340" stroke="currentColor" stroke-width="1" opacity="0.3" />

  <!-- Nodes -->
  <circle cx="200" cy="60" r="8" fill="currentColor" opacity="0.6" />
  <circle cx="120" cy="150" r="6" fill="currentColor" opacity="0.4" />
  <circle cx="280" cy="150" r="6" fill="currentColor" opacity="0.4" />
  <circle cx="80" cy="250" r="5" fill="currentColor" opacity="0.3" />
  <circle cx="200" cy="250" r="7" fill="currentColor" opacity="0.5" />
  <circle cx="320" cy="250" r="5" fill="currentColor" opacity="0.3" />
  <circle cx="160" cy="340" r="6" fill="currentColor" opacity="0.4" />
  <circle cx="260" cy="340" r="6" fill="currentColor" opacity="0.4" />

  <!-- Extra floating nodes -->
  <circle cx="50" cy="170" r="3" fill="currentColor" opacity="0.15" />
  <circle cx="350" cy="180" r="3" fill="currentColor" opacity="0.15" />
  <circle cx="40" cy="320" r="2" fill="currentColor" opacity="0.1" />
  <circle cx="360" cy="310" r="2" fill="currentColor" opacity="0.1" />
</svg>
