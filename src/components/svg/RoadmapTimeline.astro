---
import IsoDefs from './IsoDefs.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const phases = [
  { label: 'PHASE 1: FOUNDATION', start: 0, end: 2, isFuture: false },
  { label: 'PHASE 2: DISTRIBUTION', start: 2, end: 4, isFuture: false },
  { label: 'PHASE 3: MATURITY', start: 4, end: 8, isFuture: false },
  { label: 'PHASE 4: ECOSYSTEM', start: 6, end: 9, isFuture: true },
];

const nowWeek = 0.3;
const maxWeek = 9;

// Layout constants
const LEFT = 30;
const TOP = 40;
const RIGHT = 500;
const BAR_H = 36;
const BAR_GAP = 8;
const CHART_W = RIGHT - LEFT;

// Convert week to X position
const weekToX = (week: number) => LEFT + (week / maxWeek) * CHART_W;

// Week markers
const weekMarkers = [1, 2, 4, 6, 8].map((w) => ({
  week: w,
  x: weekToX(w),
}));

// Phase bars
const bars = phases.map((phase, i) => {
  const x = weekToX(phase.start);
  const w = weekToX(phase.end) - x;
  const y = TOP + 30 + i * (BAR_H + BAR_GAP);
  const opacities = [1.0, 0.7, 0.5, 0.4];
  return { ...phase, x, w, y, opacity: opacities[i], index: i };
});

const nowX = weekToX(nowWeek);
const chartBottom = TOP + 30 + phases.length * (BAR_H + BAR_GAP);
---
<svg
  viewBox="0 0 520 260"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  data-svg-animate
>
  <IsoDefs />

  <!-- Time axis line -->
  <g class="svg-reveal svg-reveal-d1">
    <line
      x1={LEFT}
      y1={TOP + 20}
      x2={RIGHT}
      y2={TOP + 20}
      stroke="currentColor"
      stroke-width="0.75"
      opacity="0.2"
    />

    <!-- Week tick marks and labels -->
    {weekMarkers.map((wm) => (
      <g>
        <line
          x1={wm.x}
          y1={TOP + 16}
          x2={wm.x}
          y2={TOP + 24}
          stroke="currentColor"
          stroke-width="0.75"
          opacity="0.3"
        />
        <text
          x={wm.x}
          y={TOP + 10}
          text-anchor="middle"
          fill="currentColor"
          font-family="var(--font-mono)"
          font-size="10"
          opacity="0.5"
        >W{wm.week}</text>
      </g>
    ))}
  </g>

  <!-- Phase bars -->
  {bars.map((b) => (
    <g class={`bar-grow-x svg-reveal-d${b.index + 2}`} style={`transform-origin: ${b.x}px ${b.y + BAR_H / 2}px`}>
      <rect
        x={b.x}
        y={b.y}
        width={b.w}
        height={BAR_H}
        rx="3"
        fill={b.isFuture ? 'none' : 'var(--color-amber-dim)'}
        stroke="var(--color-amber)"
        stroke-width={b.isFuture ? 1 : 0.8}
        stroke-dasharray={b.isFuture ? '6 3' : 'none'}
        opacity={b.opacity}
      />

      <!-- Phase label inside bar -->
      <text
        x={b.x + 12}
        y={b.y + BAR_H / 2 + 4}
        fill="var(--color-amber)"
        font-family="var(--font-mono)"
        font-size="11"
        letter-spacing="0.06em"
        opacity={b.isFuture ? 0.5 : 0.9}
      >{b.label}</text>
    </g>
  ))}

  <!-- NOW marker — vertical line spanning all bars -->
  <g class="svg-reveal svg-reveal-d1">
    <line
      x1={nowX}
      y1={TOP + 25}
      x2={nowX}
      y2={chartBottom}
      stroke="var(--color-amber)"
      stroke-width="1.5"
      opacity="0.6"
    />
    <!-- Pulsing dot at top -->
    <circle
      cx={nowX}
      cy={TOP + 25}
      r="4"
      fill="var(--color-amber)"
      opacity="0.8"
    />
    <circle
      cx={nowX}
      cy={TOP + 25}
      r="7"
      fill="none"
      stroke="var(--color-amber)"
      stroke-width="0.5"
      opacity="0.3"
      class="iso-breathe"
    />
    <text
      x={nowX}
      y={TOP + 2}
      text-anchor="middle"
      fill="var(--color-amber)"
      font-family="var(--font-mono)"
      font-size="10"
      font-weight="bold"
      letter-spacing="0.1em"
    >NOW</text>
  </g>
</svg>
