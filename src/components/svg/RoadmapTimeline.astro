---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const phases = [
  { label: 'PHASE 1: FOUNDATION', start: 0, end: 2, y: 55, opacity: 1 },
  { label: 'PHASE 2: DISTRIBUTION', start: 2, end: 4, y: 95, opacity: 0.6 },
  { label: 'PHASE 3: MATURITY', start: 4, end: 8, y: 135, opacity: 0.6 },
  { label: 'PHASE 4: ECOSYSTEM', start: 6, end: 9, y: 175, opacity: 0.5 },
];

const weekScale = (week: number) => 50 + (week / 9) * 420;
const nowWeek = 0.3; // ~1.5 days into week 1
---
<svg
  viewBox="0 0 510 220"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <!-- Week markers -->
  {[0, 1, 2, 4, 6, 8].map((week) => (
    <g>
      <line
        x1={weekScale(week)}
        y1="35"
        x2={weekScale(week)}
        y2="210"
        stroke="currentColor"
        stroke-width="0.5"
        stroke-dasharray="3 3"
        opacity="0.15"
      />
      <text
        x={weekScale(week)}
        y="28"
        text-anchor="middle"
        fill="currentColor"
        font-family="var(--font-mono)"
        font-size="11"
        opacity="0.6"
      >
        W{week}
      </text>
    </g>
  ))}

  <!-- NOW indicator -->
  <line
    x1={weekScale(nowWeek)}
    y1="35"
    x2={weekScale(nowWeek)}
    y2="210"
    stroke="var(--color-amber)"
    stroke-width="1.5"
    stroke-dasharray="4 3"
    opacity="0.8"
  />
  <text
    x={weekScale(nowWeek)}
    y="28"
    text-anchor="middle"
    fill="var(--color-amber)"
    font-family="var(--font-mono)"
    font-size="9"
    font-weight="bold"
    letter-spacing="0.1em"
  >NOW</text>

  <!-- Phase bars -->
  {phases.map((phase) => {
    const x = weekScale(phase.start);
    const width = weekScale(phase.end) - x;
    const isLast = phase.opacity === 0.5;
    return (
      <g>
        <rect
          x={x}
          y={phase.y}
          width={width}
          height="30"
          rx="3"
          fill="var(--color-amber-dim)"
          stroke="var(--color-amber)"
          stroke-width={isLast ? 0.75 : 1}
          stroke-dasharray={isLast ? '6 3' : 'none'}
          opacity={phase.opacity}
        />
        <text
          x={x + 10}
          y={phase.y + 20}
          fill="var(--color-amber)"
          font-family="var(--font-mono)"
          font-size="10"
          letter-spacing="0.06em"
          opacity={phase.opacity}
        >
          {phase.label}
        </text>
      </g>
    );
  })}
</svg>
