---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 400 400"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <!-- Concentric rings -->
  <circle cx="200" cy="200" r="175" stroke="currentColor" stroke-width="0.75" opacity="0.15" />
  <circle cx="200" cy="200" r="125" stroke="currentColor" stroke-width="1" opacity="0.25" />
  <circle cx="200" cy="200" r="72" stroke="currentColor" stroke-width="1.25" opacity="0.4" />

  <!-- Center node -->
  <circle cx="200" cy="200" r="32" fill="var(--color-amber-dim)" stroke="var(--color-amber)" stroke-width="1.5" />
  <text
    x="200"
    y="205"
    text-anchor="middle"
    fill="var(--color-amber)"
    font-family="var(--font-mono)"
    font-size="12"
    letter-spacing="0.15em"
  >
    STAGENT
  </text>

  <!-- Orbit labels -->
  <text x="200" y="148" text-anchor="middle" fill="currentColor" opacity="0.4" font-family="var(--font-mono)" font-size="11" letter-spacing="0.08em">HARNESS</text>
  <text x="200" y="95" text-anchor="middle" fill="currentColor" opacity="0.3" font-family="var(--font-mono)" font-size="11" letter-spacing="0.08em">ORCHESTRATION</text>
  <text x="200" y="42" text-anchor="middle" fill="currentColor" opacity="0.2" font-family="var(--font-mono)" font-size="11" letter-spacing="0.08em">INFRASTRUCTURE</text>

  <!-- Satellite nodes on orbits -->
  <circle cx="325" cy="200" r="5" fill="currentColor" opacity="0.3" />
  <circle cx="75" cy="200" r="5" fill="currentColor" opacity="0.3" />
  <circle cx="200" cy="325" r="4" fill="currentColor" opacity="0.2" />
  <circle cx="295" cy="105" r="4" fill="currentColor" opacity="0.2" />
  <circle cx="105" cy="295" r="4" fill="currentColor" opacity="0.2" />
  <circle cx="280" cy="145" r="4.5" fill="currentColor" opacity="0.35" />
  <circle cx="120" cy="145" r="4.5" fill="currentColor" opacity="0.35" />
</svg>
