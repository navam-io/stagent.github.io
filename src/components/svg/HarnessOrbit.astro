---
import { isoProject, isoEllipse, isoPlatform, isoGridLines } from '../../utils/isometric';
import IsoDefs from './IsoDefs.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// Larger center platform so STAGENT text fits inside the diamond
const centerPlatform = isoPlatform(-35, -35, 0, 70, 70, 6);
const centerTop = isoProject(0, 0, 6);
const centerGrid = isoGridLines(-35, -35, 6, 70, 70, 5);

// Orbit ellipses — scaled up to match larger center
const orbits = [
  { label: 'HARNESS', radius: 75, opacity: 0.5, color: 'var(--color-amber)' },
  { label: 'ORCHESTRATION', radius: 120, opacity: 0.4, color: 'var(--color-teal)' },
  { label: 'INFRASTRUCTURE', radius: 165, opacity: 0.25, color: 'currentColor' },
];

const orbitEllipses = orbits.map((o) => ({
  ...o,
  ...isoEllipse(0, 0, 6, o.radius),
  labelPos: isoProject(0, -o.radius, 6),
}));

// Satellites — pushed out to match larger orbits
const satellites = [
  { x: 75, y: 0, z: 15, r: 5.5, delay: 'iso-float', orbitIdx: 0 },
  { x: -75, y: 0, z: 12, r: 5.5, delay: 'iso-float iso-float-d1', orbitIdx: 0 },
  { x: 0, y: 75, z: 18, r: 4.5, delay: 'iso-float iso-float-d2', orbitIdx: 0 },
  { x: 55, y: -55, z: 10, r: 4.5, delay: 'iso-float iso-float-d3', orbitIdx: 1 },
  { x: -55, y: 55, z: 14, r: 4.5, delay: 'iso-float iso-float-d4', orbitIdx: 1 },
  { x: 110, y: -70, z: 8, r: 4, delay: 'iso-float iso-float-d1', orbitIdx: 2 },
  { x: -110, y: 70, z: 6, r: 4, delay: 'iso-float iso-float-d2', orbitIdx: 2 },
].map((s) => ({
  ...s,
  p: isoProject(s.x, s.y, s.z),
  dropTo: isoProject(s.x, s.y, 0),
}));

// Group satellites by orbit
const satellitesByOrbit = [0, 1, 2].map((idx) => satellites.filter((s) => s.orbitIdx === idx));
---
<svg
  viewBox="0 0 500 320"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  data-svg-animate
>
  <IsoDefs />

  <style>
    .orbit-group { transition: opacity 0.2s ease; }
    .orbit-group:hover { opacity: 1 !important; }
    .orbit-group:hover ellipse { stroke-width: 1.5; }
    .orbit-group:hover circle { opacity: 0.6; }
    .orbit-group:hover text { opacity: 0.9; }
  </style>

  <g transform="translate(250, 150)">
    <!-- Orbit rings + their satellites, grouped for hover -->
    {orbitEllipses.map((o, oi) => (
      <g class={`orbit-group svg-reveal svg-reveal-d${oi + 2}`} style={`opacity: ${o.opacity}`}>
        <ellipse
          cx={o.cx}
          cy={o.cy}
          rx={o.rx}
          ry={o.ry}
          stroke={o.color}
          stroke-width="0.75"
          fill="none"
          stroke-dasharray="4 3"
        />
        <!-- Orbit label -->
        <text
          x={o.labelPos.x}
          y={o.labelPos.y - 6}
          text-anchor="middle"
          fill={o.color}
          font-family="var(--font-mono)"
          font-size="11"
          letter-spacing="0.08em"
          opacity="0.8"
        >
          {o.label}
        </text>

        <!-- Satellites in this orbit -->
        {satellitesByOrbit[oi].map((s) => (
          <g class={s.delay}>
            <line
              x1={s.p.x}
              y1={s.p.y}
              x2={s.dropTo.x}
              y2={s.dropTo.y}
              stroke="currentColor"
              stroke-width="0.3"
              stroke-dasharray="2 3"
              opacity="0.08"
            />
            <circle
              cx={s.p.x}
              cy={s.p.y}
              r={s.r}
              fill={o.color}
              opacity="0.35"
            />
          </g>
        ))}
      </g>
    ))}

    <!-- Center platform -->
    <g class="svg-reveal svg-reveal-d1">
      <polygon
        points={centerPlatform.left}
        fill="url(#amber-side-fade)"
        stroke="var(--color-amber)"
        stroke-width="0.75"
        stroke-opacity="0.5"
      />
      <polygon
        points={centerPlatform.right}
        fill="url(#amber-side-right)"
        stroke="var(--color-amber)"
        stroke-width="0.75"
        stroke-opacity="0.5"
      />
      <polygon
        points={centerPlatform.top}
        fill="var(--color-amber-dim)"
        stroke="var(--color-amber)"
        stroke-width="1.5"
        class="iso-breathe"
      />

      <!-- Grid on center platform -->
      {centerGrid.map((d) => (
        <path
          d={d}
          stroke="var(--color-amber)"
          stroke-width="0.3"
          opacity="0.12"
        />
      ))}

      <!-- STAGENT label — now fits inside the larger diamond -->
      <text
        x={centerTop.x}
        y={centerTop.y + 4}
        text-anchor="middle"
        fill="var(--color-amber)"
        font-family="var(--font-mono)"
        font-size="13"
        letter-spacing="0.15em"
      >
        STAGENT
      </text>

      <!-- Amber glow on center -->
      <polygon
        points={centerPlatform.top}
        fill="none"
        filter="url(#amber-glow)"
        stroke="var(--color-amber)"
        stroke-width="0.5"
        opacity="0.3"
        class="iso-glow"
      />
    </g>
  </g>
</svg>
