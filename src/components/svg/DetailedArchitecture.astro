---
/**
 * 3-layer detailed architecture: Browser → Next.js Server → External Services
 * OKLCH palette with scroll-reveal animations, inline SVG icons, animated connectors
 */
---
<svg viewBox="0 0 960 560" xmlns="http://www.w3.org/2000/svg" class="w-full mx-auto" data-svg-animate>
  <defs>
    <linearGradient id="da-browser-grad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="oklch(0.7 0.15 195)" stop-opacity="0.2" />
      <stop offset="100%" stop-color="oklch(0.65 0.18 250)" stop-opacity="0.08" />
    </linearGradient>
    <linearGradient id="da-server-grad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="oklch(0.65 0.18 250)" stop-opacity="0.15" />
      <stop offset="100%" stop-color="oklch(0.65 0.18 250)" stop-opacity="0.05" />
    </linearGradient>
    <linearGradient id="da-external-grad" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%" stop-color="oklch(0.6 0.15 300)" stop-opacity="0.15" />
      <stop offset="100%" stop-color="oklch(0.6 0.15 300)" stop-opacity="0.05" />
    </linearGradient>
  </defs>
  <style>
    @keyframes dash-flow {
      to { stroke-dashoffset: -14; }
    }
    .connector-flow {
      stroke-dasharray: 4 3;
      animation: dash-flow 0.8s linear infinite;
    }
    @media (prefers-reduced-motion: reduce) {
      .connector-flow { animation: none; }
    }
  </style>

  <!-- ═══════════════════════════════════════════ -->
  <!-- BROWSER LAYER                               -->
  <!-- ═══════════════════════════════════════════ -->
  <g class="svg-reveal">
    <rect x="20" y="16" width="920" height="110" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <rect x="20" y="16" width="4" height="110" rx="2" fill="oklch(0.7 0.15 195)" />
    <!-- Globe icon — centered with label -->
    <g transform="translate(44, 28) scale(0.75)" fill="none" stroke="oklch(0.7 0.15 195)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10" />
      <line x1="2" y1="12" x2="22" y2="12" />
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
    </g>
    <text x="70" y="42" fill="oklch(0.7 0.15 195)" font-family="var(--font-mono)" font-size="13" font-weight="700" letter-spacing="1.5">BROWSER</text>
    <text x="168" y="42" fill="oklch(0.5 0.02 250)" font-family="var(--font-body)" font-size="11">React 19</text>
  </g>

  <!-- Route pills — batch 1 (first 5) -->
  <g class="svg-reveal svg-reveal-d1" font-family="var(--font-mono)" font-size="10.5">
    <rect x="42" y="56" width="72" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="78" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Home</text>

    <rect x="122" y="56" width="92" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="168" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Dashboard</text>

    <rect x="222" y="56" width="82" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="263" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Projects</text>

    <rect x="312" y="56" width="60" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="342" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Docs</text>

    <rect x="380" y="56" width="88" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="424" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Workflows</text>
  </g>

  <!-- Route pills — batch 2 (last 5) -->
  <g class="svg-reveal svg-reveal-d2" font-family="var(--font-mono)" font-size="10.5">
    <rect x="476" y="56" width="76" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="514" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Profiles</text>

    <rect x="560" y="56" width="86" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="603" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Schedules</text>

    <rect x="654" y="56" width="64" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="686" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Inbox</text>

    <rect x="726" y="56" width="76" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="764" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Monitor</text>

    <rect x="810" y="56" width="76" height="24" rx="4" fill="oklch(0.22 0.02 250)" stroke="oklch(0.3 0.03 250)" stroke-width="0.75" />
    <text x="848" y="72" fill="oklch(0.7 0.15 195)" text-anchor="middle">Settings</text>
  </g>

  <!-- Browser subtitle -->
  <g class="svg-reveal svg-reveal-d2">
    <text x="42" y="106" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="10">10 operator-facing surfaces for governed AI operations</text>
  </g>

  <!-- ═══════════════════════════════════════════ -->
  <!-- CONNECTION: Browser → Server                -->
  <!-- ═══════════════════════════════════════════ -->
  <g class="svg-reveal svg-reveal-d3">
    <!-- Animated flowing dashes -->
    <line x1="240" y1="126" x2="240" y2="160" stroke="oklch(0.5 0.1 250)" stroke-width="1.2" class="connector-flow" />
    <line x1="700" y1="126" x2="700" y2="160" stroke="oklch(0.5 0.1 250)" stroke-width="1.2" class="connector-flow" />
    <!-- Labels with padding from lines -->
    <text x="250" y="148" fill="oklch(0.5 0.08 250)" font-family="var(--font-mono)" font-size="9">Server Components (direct DB queries)</text>
    <text x="710" y="148" fill="oklch(0.5 0.08 250)" font-family="var(--font-mono)" font-size="9">API Routes</text>
  </g>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SERVER LAYER                                -->
  <!-- ═══════════════════════════════════════════ -->
  <g class="svg-reveal svg-reveal-d3">
    <rect x="20" y="160" width="920" height="200" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <rect x="20" y="160" width="4" height="200" rx="2" fill="oklch(0.65 0.18 250)" />
    <!-- Server/stack icon — centered with label -->
    <g transform="translate(44, 172) scale(0.75)" fill="none" stroke="oklch(0.65 0.18 250)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="2" width="20" height="8" rx="2" />
      <rect x="2" y="14" width="20" height="8" rx="2" />
      <circle cx="6" cy="6" r="1" fill="oklch(0.65 0.18 250)" />
      <circle cx="6" cy="18" r="1" fill="oklch(0.65 0.18 250)" />
    </g>
    <text x="70" y="186" fill="oklch(0.65 0.18 250)" font-family="var(--font-mono)" font-size="13" font-weight="700" letter-spacing="1.5">NEXT.JS 16 SERVER</text>
  </g>

  <!-- Service grid — Row 1 -->
  <!-- Drizzle ORM -->
  <g class="ring-expand svg-reveal-d4">
    <rect x="42" y="200" width="208" height="60" rx="6" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="42" y="200" width="3" height="60" rx="1.5" fill="oklch(0.7 0.15 195)" />
    <!-- Database icon — large, vertically centered -->
    <g transform="translate(54, 216) scale(1.2)" fill="none" stroke="oklch(0.7 0.15 195)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <ellipse cx="12" cy="5" rx="9" ry="3" />
      <path d="M21 5v14a9 3 0 0 1-18 0V5" />
    </g>
    <text x="92" y="226" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Drizzle ORM</text>
    <text x="92" y="242" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">SQLite · WAL mode</text>
  </g>

  <!-- Runtime Registry -->
  <g class="ring-expand svg-reveal-d4">
    <rect x="262" y="200" width="208" height="60" rx="6" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="262" y="200" width="3" height="60" rx="1.5" fill="oklch(0.65 0.18 250)" />
    <!-- CPU/chip icon — large, vertically centered -->
    <g transform="translate(274, 216) scale(1.2)" fill="none" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="4" y="4" width="16" height="16" rx="2" />
      <line x1="9" y1="1" x2="9" y2="4" /><line x1="15" y1="1" x2="15" y2="4" />
      <line x1="9" y1="20" x2="9" y2="23" /><line x1="15" y1="20" x2="15" y2="23" />
      <line x1="1" y1="9" x2="4" y2="9" /><line x1="1" y1="15" x2="4" y2="15" />
      <line x1="20" y1="9" x2="23" y2="9" /><line x1="20" y1="15" x2="23" y2="15" />
    </g>
    <text x="312" y="226" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Runtime Registry</text>
    <text x="312" y="242" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">Claude + OpenAI adapters</text>
  </g>

  <!-- SSE Stream -->
  <g class="ring-expand svg-reveal-d4">
    <rect x="482" y="200" width="208" height="60" rx="6" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="482" y="200" width="3" height="60" rx="1.5" fill="oklch(0.6 0.15 300)" />
    <!-- Signal/radio icon — large, vertically centered -->
    <g transform="translate(494, 216) scale(1.2)" fill="none" stroke="oklch(0.6 0.15 300)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 20h.01" />
      <path d="M8.5 16.5a5 5 0 0 1 7 0" />
      <path d="M5 13a10 10 0 0 1 14 0" />
      <path d="M1.5 9.5a15 15 0 0 1 21 0" />
    </g>
    <text x="532" y="226" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">SSE Stream</text>
    <text x="532" y="242" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">Real-time event push</text>
  </g>

  <!-- Profile Engine -->
  <g class="ring-expand svg-reveal-d4">
    <rect x="702" y="200" width="220" height="60" rx="6" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="702" y="200" width="3" height="60" rx="1.5" fill="oklch(0.7 0.15 75)" />
    <!-- User/person icon — large, vertically centered -->
    <g transform="translate(714, 216) scale(1.2)" fill="none" stroke="oklch(0.7 0.15 75)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="8" r="5" />
      <path d="M20 21a8 8 0 0 0-16 0" />
    </g>
    <text x="752" y="226" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Profile Engine</text>
    <text x="752" y="242" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">Instructions · tool policy</text>
  </g>

  <!-- Service grid — Row 2 -->
  <!-- Scheduler Engine -->
  <g class="ring-expand svg-reveal-d5">
    <rect x="42" y="272" width="208" height="60" rx="6" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="42" y="272" width="3" height="60" rx="1.5" fill="oklch(0.7 0.18 150)" />
    <!-- Clock icon — large, vertically centered -->
    <g transform="translate(54, 288) scale(1.2)" fill="none" stroke="oklch(0.7 0.18 150)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10" />
      <polyline points="12 6 12 12 16 14" />
    </g>
    <text x="92" y="298" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Scheduler Engine</text>
    <text x="92" y="314" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">Cron · one-shot triggers</text>
  </g>

  <!-- Workflow Engine -->
  <g class="ring-expand svg-reveal-d5">
    <rect x="262" y="272" width="208" height="60" rx="6" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="262" y="272" width="3" height="60" rx="1.5" fill="oklch(0.7 0.15 340)" />
    <!-- GitBranch/flow icon — large, vertically centered -->
    <g transform="translate(274, 288) scale(1.2)" fill="none" stroke="oklch(0.7 0.15 340)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="6" y1="3" x2="6" y2="15" />
      <circle cx="18" cy="6" r="3" />
      <circle cx="6" cy="18" r="3" />
      <path d="M18 9a9 9 0 0 1-9 9" />
    </g>
    <text x="312" y="298" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Workflow Engine</text>
    <text x="312" y="314" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">5 orchestration patterns</text>
  </g>

  <!-- Permission Gate -->
  <g class="ring-expand svg-reveal-d5">
    <rect x="482" y="272" width="208" height="60" rx="6" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="482" y="272" width="3" height="60" rx="1.5" fill="oklch(0.65 0.2 25)" />
    <!-- Shield icon — large, vertically centered -->
    <g transform="translate(494, 288) scale(1.2)" fill="none" stroke="oklch(0.65 0.2 25)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
    </g>
    <text x="532" y="298" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Permission Gate</text>
    <text x="532" y="314" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">canUseTool enforcement</text>
  </g>

  <!-- Doc Processor -->
  <g class="ring-expand svg-reveal-d5">
    <rect x="702" y="272" width="220" height="60" rx="6" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="702" y="272" width="3" height="60" rx="1.5" fill="oklch(0.65 0.15 180)" />
    <!-- FileText icon — large, vertically centered -->
    <g transform="translate(714, 288) scale(1.2)" fill="none" stroke="oklch(0.65 0.15 180)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
      <polyline points="14 2 14 8 20 8" />
      <line x1="8" y1="13" x2="16" y2="13" />
      <line x1="8" y1="17" x2="16" y2="17" />
    </g>
    <text x="752" y="298" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11.5" font-weight="600">Doc Processor</text>
    <text x="752" y="314" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">Upload · extraction · context</text>
  </g>

  <!-- Server subtitle -->
  <g class="svg-reveal svg-reveal-d5">
    <text x="42" y="350" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="10">8 service modules — governed execution, reusable automation, real-time visibility</text>
  </g>

  <!-- ═══════════════════════════════════════════ -->
  <!-- CONNECTION: Server → External               -->
  <!-- ═══════════════════════════════════════════ -->
  <g class="svg-reveal svg-reveal-d5">
    <!-- Animated flowing dashes -->
    <line x1="170" y1="362" x2="170" y2="396" stroke="oklch(0.5 0.1 250)" stroke-width="1.2" class="connector-flow" />
    <line x1="480" y1="362" x2="480" y2="396" stroke="oklch(0.5 0.1 250)" stroke-width="1.2" class="connector-flow" />
    <line x1="760" y1="362" x2="760" y2="396" stroke="oklch(0.5 0.1 250)" stroke-width="1.2" class="connector-flow" />
    <!-- Labels with padding -->
    <text x="180" y="383" fill="oklch(0.5 0.08 250)" font-family="var(--font-mono)" font-size="9">SQLite queries</text>
    <text x="490" y="383" fill="oklch(0.5 0.08 250)" font-family="var(--font-mono)" font-size="9">Runtime API</text>
    <text x="770" y="383" fill="oklch(0.5 0.08 250)" font-family="var(--font-mono)" font-size="9">SSE push</text>
  </g>

  <!-- ═══════════════════════════════════════════ -->
  <!-- EXTERNAL LAYER                              -->
  <!-- ═══════════════════════════════════════════ -->
  <g class="svg-reveal svg-reveal-d5">
    <rect x="20" y="398" width="920" height="108" rx="8" fill="oklch(0.19 0.02 250)" stroke="oklch(0.25 0.02 250)" stroke-width="1" />
    <rect x="20" y="398" width="4" height="108" rx="2" fill="oklch(0.6 0.15 300)" />
    <!-- Cloud icon — centered with label -->
    <g transform="translate(44, 408) scale(0.75)" fill="none" stroke="oklch(0.6 0.15 300)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" />
    </g>
    <text x="70" y="424" fill="oklch(0.6 0.15 300)" font-family="var(--font-mono)" font-size="13" font-weight="700" letter-spacing="1.5">EXTERNAL</text>
  </g>

  <!-- ~/.stagent/ -->
  <g class="svg-reveal svg-reveal-d6">
    <rect x="42" y="438" width="270" height="52" rx="5" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="42" y="438" width="3" height="52" rx="1.5" fill="oklch(0.7 0.15 195)" />
    <!-- HardDrive icon — large, vertically centered -->
    <g transform="translate(54, 452) scale(1.0)" fill="none" stroke="oklch(0.7 0.15 195)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="22" y1="12" x2="2" y2="12" />
      <path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z" />
      <line x1="6" y1="16" x2="6.01" y2="16" />
      <line x1="10" y1="16" x2="10.01" y2="16" />
    </g>
    <text x="86" y="460" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11" font-weight="600">~/.stagent/</text>
    <text x="86" y="477" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">SQLite DB · local files · audit trail</text>
  </g>

  <!-- Runtime Backends -->
  <g class="svg-reveal svg-reveal-d6">
    <rect x="326" y="438" width="310" height="52" rx="5" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
    <rect x="326" y="438" width="3" height="52" rx="1.5" fill="oklch(0.65 0.18 250)" />
    <!-- Zap/bolt icon — large, vertically centered -->
    <g transform="translate(338, 452) scale(1.0)" fill="none" stroke="oklch(0.65 0.18 250)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
    </g>
    <text x="370" y="460" fill="oklch(0.75 0.05 250)" font-family="var(--font-mono)" font-size="11" font-weight="600">Runtime Backends</text>
    <text x="370" y="477" fill="oklch(0.45 0.02 250)" font-family="var(--font-body)" font-size="9.5">Anthropic (Claude Agent SDK) · OpenAI (Codex)</text>
  </g>

  <!-- EventSource -->
  <g class="svg-reveal svg-reveal-d6">
    <rect x="650" y="438" width="272" height="52" rx="5" fill="oklch(0.16 0.02 250)" stroke="oklch(0.28 0.03 250)" stroke-width="0.75" />
