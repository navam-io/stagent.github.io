---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 420 180"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <!-- Three zones -->
  <rect x="20" y="30" width="120" height="70" rx="4" fill="currentColor" opacity="0.12" stroke="currentColor" stroke-width="0.75" />
  <rect x="150" y="30" width="120" height="70" rx="4" fill="currentColor" opacity="0.06" stroke="currentColor" stroke-width="0.75" stroke-dasharray="4 3" />
  <rect x="280" y="30" width="120" height="70" rx="4" fill="var(--color-amber-dim)" stroke="var(--color-amber)" stroke-width="1.5" />

  <!-- Zone labels -->
  <text x="80" y="69" text-anchor="middle" fill="currentColor" font-family="var(--font-mono)" font-size="12" letter-spacing="0.08em" opacity="0.7">SUPERVISED</text>
  <text x="210" y="62" text-anchor="middle" fill="currentColor" font-family="var(--font-mono)" font-size="11" letter-spacing="0.08em" opacity="0.6">SEMI-</text>
  <text x="210" y="76" text-anchor="middle" fill="currentColor" font-family="var(--font-mono)" font-size="11" letter-spacing="0.08em" opacity="0.6">AUTONOMOUS</text>
  <text x="340" y="69" text-anchor="middle" fill="var(--color-amber)" font-family="var(--font-mono)" font-size="12" letter-spacing="0.08em">AUTONOMOUS</text>

  <!-- Vertical dashed dividers -->
  <line x1="145" y1="25" x2="145" y2="105" stroke="currentColor" stroke-width="0.5" stroke-dasharray="3 3" opacity="0.25" />
  <line x1="275" y1="25" x2="275" y2="105" stroke="currentColor" stroke-width="0.5" stroke-dasharray="3 3" opacity="0.25" />

  <!-- Arrow below -->
  <line x1="40" y1="130" x2="380" y2="130" stroke="currentColor" stroke-width="0.75" opacity="0.3" />
  <polygon points="385,130 378,127 378,133" fill="currentColor" opacity="0.3" />
  <text x="210" y="155" text-anchor="middle" fill="currentColor" font-family="var(--font-mono)" font-size="10" letter-spacing="0.06em" opacity="0.55">
    TRUST INCREASES WITH DEMONSTRATED COMPETENCE
  </text>
</svg>
