---
import { velocity, intents, stats } from '../../data/progress';
import IsoDefs from './IsoDefs.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// ── Velocity Line Chart (top section) ──
const CHART_LEFT = 65;
const CHART_TOP = 48;
const CHART_W = 490;
const CHART_H = 140;
const CHART_BOTTOM = CHART_TOP + CHART_H;

const maxDay = 4;
const maxLoc = 20000;

// Convert data to chart coordinates
const dayToX = (day: number) => CHART_LEFT + (day / maxDay) * CHART_W;
const locToY = (loc: number) => CHART_BOTTOM - (loc / maxLoc) * CHART_H;

const chartPoints = velocity.map((p) => ({
  ...p,
  cx: dayToX(p.day),
  cy: locToY(p.loc),
}));

// Polyline points for the data line
const linePointsStr = chartPoints.map((p) => `${p.cx},${p.cy}`).join(' ');

// Polygon points for area fill (close back to baseline)
const areaPointsStr = [
  `${chartPoints[0].cx},${CHART_BOTTOM}`,
  ...chartPoints.map((p) => `${p.cx},${p.cy}`),
  `${chartPoints[chartPoints.length - 1].cx},${CHART_BOTTOM}`,
].join(' ');

// Y-axis gridlines
const yGridValues = [5000, 10000, 15000, 20000];

// X-axis day labels (real + projected)
const allDayLabels = [
  ...velocity.map((p) => ({ x: dayToX(p.day), label: p.label, projected: false })),
  { x: dayToX(3), label: 'Day 3', projected: true },
  { x: dayToX(4), label: 'Day 4', projected: true },
];

// ── Projection curve ──
// Linear projection from last two data points (Day 1→2 growth rate: 2761 LOC/day)
const lastPoint = velocity[velocity.length - 1];
const prevPoint = velocity[velocity.length - 2];
const dailyRate = lastPoint.loc - prevPoint.loc;

// Generate projection line from Day 2 to Day 4
const projStart = { x: dayToX(lastPoint.day), y: locToY(lastPoint.loc) };
const projEndDay = 4;
const projEndLocVal = lastPoint.loc + dailyRate * (projEndDay - lastPoint.day);
const projEnd = { x: dayToX(projEndDay), y: locToY(projEndLocVal) };

// Simple straight dashed line for projection
const projPathStr = `M${projStart.x},${projStart.y} L${projEnd.x},${projEnd.y}`;

// Projected endpoint label
const projEndLoc = Math.round(projEndLocVal);
const projEndX = projEnd.x;
const projEndY = projEnd.y;

// ── Intent Waffle Grid (bottom section) ──
const WAFFLE_TOP = 240;
const WAFFLE_LEFT = 55;
const CELL_SIZE = 16;
const CELL_GAP = 4;
const COLS = 10;

const completedCount = intents.filter((i) => i.done).length;

const waffleCells = intents.map((intent, i) => {
  const col = i % COLS;
  const row = Math.floor(i / COLS);
  const x = WAFFLE_LEFT + col * (CELL_SIZE + CELL_GAP);
  const y = WAFFLE_TOP + 25 + row * (CELL_SIZE + CELL_GAP);
  return { ...intent, x, y, index: i };
});

// Legend position (bottom-right of chart, top-aligned with waffle grid)
const LEGEND_X = CHART_LEFT + CHART_W - 100;
const LEGEND_Y = WAFFLE_TOP + 25;
---
<svg
  viewBox="0 0 580 400"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  data-svg-animate
>
  <IsoDefs />

  <style>
    .data-point { transition: transform 0.2s ease; transform-origin: center; }
    .data-point:hover { transform: scale(1.5); }
    .waffle-cell { transition: opacity 0.2s ease; }
    .waffle-cell:hover { opacity: 1 !important; }
  </style>

  <!-- ── VELOCITY LINE CHART ── -->

  <!-- Title -->
  <text
    x={CHART_LEFT}
    y={CHART_TOP - 10}
    fill="currentColor"
    font-family="var(--font-mono)"
    font-size="13"
    letter-spacing="0.1em"
    opacity="0.6"
    class="svg-reveal svg-reveal-d1"
  >CUMULATIVE LOC</text>

  <!-- Y-axis gridlines -->
  {yGridValues.map((val) => {
    const y = locToY(val);
    return (
      <g class="svg-reveal svg-reveal-d1">
        <line
          x1={CHART_LEFT}
          y1={y}
          x2={CHART_LEFT + CHART_W}
          y2={y}
          stroke="currentColor"
          stroke-width="0.5"
          stroke-dasharray="3 3"
          opacity="0.08"
        />
        <text
          x={CHART_LEFT - 8}
          y={y + 4}
          text-anchor="end"
          fill="currentColor"
          font-family="var(--font-mono)"
          font-size="10"
          opacity="0.35"
        >{(val / 1000).toFixed(0)}K</text>
      </g>
    );
  })}

  <!-- X-axis baseline -->
  <line
    x1={CHART_LEFT}
    y1={CHART_BOTTOM}
    x2={CHART_LEFT + CHART_W}
    y2={CHART_BOTTOM}
    stroke="currentColor"
    stroke-width="0.75"
    opacity="0.15"
    class="svg-reveal svg-reveal-d1"
  />

  <!-- Day labels on X-axis -->
  {allDayLabels.map((dl) => (
    <text
      x={dl.x}
      y={CHART_BOTTOM + 16}
      text-anchor="middle"
      fill={dl.projected ? 'var(--color-teal)' : 'currentColor'}
      font-family="var(--font-mono)"
      font-size="10"
      opacity={dl.projected ? 0.35 : 0.4}
      class="svg-reveal svg-reveal-d1"
    >{dl.label}</text>
  ))}

  <!-- Area fill under the data line -->
  <polygon
    points={areaPointsStr}
    fill="var(--color-amber-dim)"
    opacity="0.3"
    class="svg-reveal svg-reveal-d2"
  />

  <!-- Data line (solid) -->
  <polyline
    points={linePointsStr}
    stroke="var(--color-amber)"
    stroke-width="2"
    fill="none"
    class="svg-reveal svg-reveal-d2"
  />

  <!-- Projection curve (dashed) -->
  <path
    d={projPathStr}
    stroke="var(--color-teal)"
    stroke-width="1.5"
    stroke-dasharray="6 4"
    fill="none"
    opacity="0.5"
    class="svg-reveal svg-reveal-d3"
  />

  <!-- Projected endpoint value -->
  <text
    x={projEndX}
    y={projEndY - 12}
    text-anchor="middle"
    fill="var(--color-teal)"
    font-family="var(--font-mono)"
    font-size="10"
    opacity="0.5"
    class="svg-reveal svg-reveal-d3"
  >{projEndLoc.toLocaleString()}</text>

  <!-- "PROJECTED" label -->
  <text
    x={dayToX(3)}
    y={CHART_TOP - 10}
    text-anchor="middle"
    fill="var(--color-teal)"
    font-family="var(--font-mono)"
    font-size="9"
    letter-spacing="0.08em"
    opacity="0.35"
    class="svg-reveal svg-reveal-d3"
  >PROJECTED</text>

  <!-- Data points with value labels -->
  {chartPoints.map((cp, i) => (
    <g class={`data-point dot-pop svg-reveal-d${i + 3}`}>
      <circle
        cx={cp.cx}
        cy={cp.cy}
        r="4"
        fill="var(--color-amber)"
      />
      {cp.loc > 0 && (
        <text
          x={cp.cx}
          y={cp.cy - 12}
          text-anchor="middle"
          fill="var(--color-amber)"
          font-family="var(--font-mono)"
          font-size="11"
          font-weight="bold"
        >{cp.loc.toLocaleString()}</text>
      )}
    </g>
  ))}

  <!-- ── INTENT WAFFLE GRID ── -->

  <!-- Section label -->
  <text
    x={WAFFLE_LEFT}
    y={WAFFLE_TOP + 12}
    fill="currentColor"
    font-family="var(--font-mono)"
    font-size="12"
    letter-spacing="0.08em"
    opacity="0.6"
    class="svg-reveal svg-reveal-d3"
  >{completedCount}/{intents.length} COMPLETE</text>

  <!-- Waffle cells -->
  {waffleCells.map((cell) => (
    <g class="waffle-cell svg-reveal svg-reveal-d4" style={`opacity: ${cell.done ? 1 : 0.7}`}>
      <rect
        x={cell.x}
        y={cell.y}
        width={CELL_SIZE}
        height={CELL_SIZE}
        rx="3"
        fill={cell.done ? 'var(--color-amber-dim)' : 'var(--color-teal-dim)'}
        stroke={cell.done ? 'var(--color-amber)' : 'var(--color-teal)'}
        stroke-width={cell.done ? 1 : 0.5}
        stroke-opacity={cell.done ? 0.8 : 0.4}
      >
        <title>{cell.id}: {cell.name}</title>
      </rect>
    </g>
  ))}

  <!-- Legend (absolute positions — no group translate, avoids CSS transform override) -->
  <g class="svg-reveal svg-reveal-d5">
    <rect x={LEGEND_X} y={LEGEND_Y} width="12" height="12" rx="2"
      fill="var(--color-amber-dim)" stroke="var(--color-amber)" stroke-width="1" />
    <text x={LEGEND_X + 18} y={LEGEND_Y + 10} fill="currentColor" font-family="var(--font-mono)" font-size="10" opacity="0.5">
      COMPLETE
    </text>

    <rect x={LEGEND_X} y={LEGEND_Y + 22} width="12" height="12" rx="2"
      fill="var(--color-teal-dim)" stroke="var(--color-teal)" stroke-width="0.5" stroke-opacity="0.4" />
    <text x={LEGEND_X + 18} y={LEGEND_Y + 32} fill="currentColor" font-family="var(--font-mono)" font-size="10" opacity="0.5">
      REMAINING
    </text>
  </g>
</svg>
