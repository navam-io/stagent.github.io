---
import IsoDefs from './IsoDefs.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

const CX = 195;
const CY = 190;

const tiers = [
  { label: 'WORKING', r: 40, isCore: true, fillColor: 'var(--color-amber-dim)', strokeColor: 'var(--color-amber)', labelColor: 'var(--color-amber)', delay: 1 },
  { label: 'EPISODIC', r: 80, isCore: false, fillColor: 'var(--color-amber-dim)', strokeColor: 'var(--color-amber)', labelColor: 'var(--color-amber)', delay: 2 },
  { label: 'SEMANTIC', r: 120, isCore: false, fillColor: 'var(--color-teal-dim)', strokeColor: 'var(--color-teal)', labelColor: 'var(--color-teal)', delay: 3 },
  { label: 'PROCEDURAL', r: 160, isCore: false, fillColor: 'var(--color-teal-dim)', strokeColor: 'var(--color-teal)', labelColor: 'var(--color-teal)', delay: 4 },
];

// Stagger labels vertically so they don't overlap
// Each label gets its own Y, with a leader line from the ring edge at that Y
const TEXT_X = 390;
const labelOffsets = [-40, -14, 14, 40];

const labels = tiers.map((t, i) => {
  const labelY = CY + labelOffsets[i];
  // Ring edge x at this Y level: CX + sqrt(r² - dy²)
  const dy = labelOffsets[i];
  const ringEdgeX = CX + Math.sqrt(Math.max(0, t.r * t.r - dy * dy));
  return {
    ...t,
    ringEdgeX,
    labelY,
    textX: TEXT_X,
  };
});

// Axis positions
const AXIS_X_LEFT = CX - 175;
const AXIS_X_RIGHT = CX + 175;
---
<svg
  viewBox="0 0 500 380"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  data-svg-animate
>
  <IsoDefs />

  <style>
    .mem-ring { transition: opacity 0.2s ease; }
    .mem-ring:hover { opacity: 1 !important; }
    .mem-ring:hover circle { stroke-width: 2; }
  </style>

  <!-- Concentric rings (draw outermost first as background) -->
  {tiers.slice().reverse().map((t, i) => (
    <g class={`mem-ring ring-expand svg-reveal-d${5 - i}`} style={`opacity: ${t.isCore ? 1 : 0.7}`}>
      <circle
        cx={CX}
        cy={CY}
        r={t.r}
        fill={t.fillColor}
        stroke={t.strokeColor}
        stroke-width={t.isCore ? 1.5 : 0.8}
        stroke-opacity="0.6"
      />
    </g>
  ))}

  <!-- Core glow -->
  <circle
    cx={CX}
    cy={CY}
    r={tiers[0].r}
    fill="none"
    filter="url(#amber-glow)"
    stroke="var(--color-amber)"
    stroke-width="0.5"
    opacity="0.3"
  />

  <!-- Leader lines and labels (staggered vertically) -->
  {labels.map((l) => (
    <g class={`svg-reveal svg-reveal-d${l.delay}`}>
      <!-- Angled leader line from ring edge to label column -->
      <line
        x1={l.ringEdgeX}
        y1={l.labelY}
        x2={l.textX - 5}
        y2={l.labelY}
        stroke={l.strokeColor}
        stroke-width="0.75"
        opacity="0.3"
      />
      <!-- Small dot at ring edge -->
      <circle
        cx={l.ringEdgeX}
        cy={l.labelY}
        r="2"
        fill={l.strokeColor}
        opacity="0.5"
      />
      <text
        x={l.textX}
        y={l.labelY + 4}
        fill={l.labelColor}
        font-family="var(--font-mono)"
        font-size="11"
        letter-spacing="0.08em"
        opacity="0.8"
      >
        {l.label}
      </text>
    </g>
  ))}

  <!-- STABILITY arrow (left side, pointing down) -->
  <g class="svg-reveal svg-reveal-d5">
    <line
      x1={AXIS_X_LEFT + 15}
      y1={CY - 80}
      x2={AXIS_X_LEFT + 15}
      y2={CY + 80}
      stroke="currentColor"
      stroke-width="0.75"
      opacity="0.25"
    />
    <polygon
      points={`${AXIS_X_LEFT + 15},${CY + 86} ${AXIS_X_LEFT + 11},${CY + 76} ${AXIS_X_LEFT + 19},${CY + 76}`}
      fill="currentColor"
      opacity="0.25"
    />
    <text
      x={AXIS_X_LEFT + 15}
      y={CY + 102}
      text-anchor="middle"
      fill="currentColor"
      font-family="var(--font-mono)"
      font-size="9"
      letter-spacing="0.08em"
      opacity="0.4"
    >STABILITY</text>
  </g>

  <!-- VOLATILITY arrow (right side, pointing up) -->
  <g class="svg-reveal svg-reveal-d5">
    <line
      x1={AXIS_X_RIGHT - 15}
      y1={CY + 80}
      x2={AXIS_X_RIGHT - 15}
      y2={CY - 80}
      stroke="currentColor"
      stroke-width="0.75"
      opacity="0.25"
    />
    <polygon
      points={`${AXIS_X_RIGHT - 15},${CY - 86} ${AXIS_X_RIGHT - 19},${CY - 76} ${AXIS_X_RIGHT - 11},${CY - 76}`}
      fill="currentColor"
      opacity="0.25"
    />
    <text
      x={AXIS_X_RIGHT - 15}
      y={CY - 95}
      text-anchor="middle"
      fill="currentColor"
      font-family="var(--font-mono)"
      font-size="9"
      letter-spacing="0.08em"
      opacity="0.4"
    >VOLATILITY</text>
  </g>
</svg>
