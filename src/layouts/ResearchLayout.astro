---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/prose.css';
import { SITE, PUBLISHER } from '../data/seo';

interface Props {
  title?: string;
  description?: string;
  datePublished?: string;
  dateModified?: string;
  author?: string;
  readingTime?: string;
}

const {
  title = 'Research — Stagent',
  description = 'Governed AI agent operations: architecture, reusable automation, and the coordination layer for the agentic enterprise.',
  datePublished = '2026-03-01',
  dateModified = '2026-03-09',
  author = 'Navam',
  readingTime,
} = Astro.props;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: title,
    description,
    author: {
      '@type': 'Person',
      name: author,
    },
    publisher: PUBLISHER,
    datePublished,
    dateModified,
    wordCount: 5500,
    proficiencyLevel: 'Expert',
    url: `${SITE.url}/research/`,
    image: `${SITE.url}/og-image.png`,
    about: [
      { '@type': 'Thing', name: 'AI task management' },
      { '@type': 'Thing', name: 'Human-in-the-loop AI' },
      { '@type': 'Thing', name: 'Claude Agent SDK' },
      { '@type': 'Thing', name: 'Agent governance' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: SITE.url,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Research',
        item: `${SITE.url}/research/`,
      },
    ],
  },
];
---
<Layout
  title={title}
  description={description}
  ogType="article"
  article={{ datePublished, dateModified, author }}
  jsonLd={jsonLd}
>
  <!-- Citation meta tags for Google Scholar / AI discovery -->
  <meta slot="head" name="citation_title" content={title} />
  <meta slot="head" name="citation_author" content={author} />
  <meta slot="head" name="citation_date" content={datePublished} />
  <meta slot="head" name="citation_public_url" content={`${SITE.url}/research/`} />

  <!-- Reading progress bar -->
  <div
    id="reading-progress"
    class="fixed top-0 left-0 h-[2px] bg-primary z-50 transition-none"
    style="width: 0%"
  ></div>

  <Nav />

  <!-- Content -->
  <main class="max-w-[72ch] mx-auto px-6 pt-28 pb-32">
    <article class="prose">
      <slot />
    </article>
  </main>

  <Footer />

  <!-- Reading progress script -->
  <script>
    function initProgress() {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;

      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        bar.style.width = `${Math.min(progress, 100)}%`;
      }

      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    initProgress();
    document.addEventListener('astro:after-swap', initProgress);
  </script>
</Layout>
